-- ==============================================
-- MAIN LOOP - الحركة والقفز
-- ==============================================
RunService.Heartbeat:Connect(function()
    pcall(function()
        local char = LP.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        
        local now = tick()
        local inMatch = IsInMatch()
        local alive = IsAlive()
        
        -- القفز (قفزتين)
        if CFG.AutoJump and inMatch and alive and now - lastJump >= CFG.JumpInterval then
            lastJump = now
            hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
            hum.Jump = true
            task.delay(0.18, function()
                pcall(function()
                    if hum and hum.Parent and hum.Health > 0 then
                        hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
                        hum.Jump = true
                    end
                end)
            end)
        end
        
        -- المشي التلقائي (فقط في المباراة)
        if CFG.AutoWalk and inMatch and alive and now - lastWalk >= 0.6 then
            lastWalk = now
            local target = hrp.Position + Dirs[math.random(1, #Dirs)] * 20
            hum:MoveTo(target)
        end
        
        -- الحركة العشوائية (فقط في المباراة)
        if CFG.RandomMove and inMatch and alive and now - lastRandom >= CFG.MoveInterval then
            lastRandom = now
            local target = hrp.Position + Dirs[math.random(1, #Dirs)] * 15
            hum:MoveTo(target)
        end
    end)
end)

-- ==============================================
-- حذف العناصر الثقيلة من الخريطة (Anti-Lag ذكي)
-- ==============================================
local function CleanHeavyElements()
    pcall(function()
        -- 1. تعطيل المؤثرات العامة
        for _, v in ipairs(Workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Fire") then
                v.Enabled = false
            end
            if v:IsA("BloomEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") then
                v.Enabled = false
            end
            if v:IsA("BasePart") then
                v.CastShadow = false
            end
        end
        
        -- 2. حذف زخارف الخريطة حسب النوع
        local mapFolder = Workspace:FindFirstChild("Map")
        if mapFolder then
            local currentMap = mapFolder:FindFirstChildWhichIsA("Model")
            if currentMap then
                local mapName = currentMap.Name
                
                -- عناصر ثقيلة حسب الخريطة
                local heavyNames = {}
                if mapName == "Birdcage" or mapName == "BirdCage" then
                    heavyNames = {"Chain", "Crystal", "Pillar", "Cage"}
                elseif mapName == "Arena" then
                    heavyNames = {"Column", "Door", "Cabin"}
                elseif mapName == "HeightFight" or mapName == "Height Fight" then
                    heavyNames = {"Torch", "FireRing"}
                elseif mapName == "Olympus" then
                    heavyNames = {"Pillar", "Stone"}
                elseif mapName == "Quarry" then
                    heavyNames = {"Tree", "Rock", "Bush"}
                elseif mapName == "EnchantedDesert" or mapName == "Enchanted Desert" then
                    heavyNames = {"Tree", "Vine", "Rock"}
                elseif mapName == "RingOfFire" or mapName == "Ring of Fire" then
                    heavyNames = {"Mountain", "Rock", "Lava"}
                elseif mapName == "Desert" then
                    heavyNames = {"Cactus"}
                elseif mapName == "GrassyClassic" or mapName == "Grassy Classic" then
                    heavyNames = {"Tree", "Grass"}
                end
                
                for _, name in ipairs(heavyNames) do
                    for _, v in ipairs(currentMap:GetDescendants()) do
                        if v.Name == name or v.Name:find(name) then
                            pcall(function() v:Destroy() end)
                        end
                    end
                end
            end
        end
    end)
end

