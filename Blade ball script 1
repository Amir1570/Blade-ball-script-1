local logList = {}
local function Log(msg, col)
    table.insert(logList, 1, {t=os.date("%H:%M:%S").."  "..msg, c=col or C.Text})
    if #logList > 50 then table.remove(logList) end
    for _, ch in ipairs(logScroll:GetChildren()) do
        if ch:IsA("TextLabel") then ch:Destroy() end
    end
    for i, e in ipairs(logList) do
        local l = Instance.new("TextLabel")
        l.Text = e.t; l.Font = Enum.Font.Code; l.TextSize = 9
        l.TextColor3 = e.c; l.BackgroundTransparency = 1
