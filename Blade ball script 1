-- ====================== كشف المباراة + Levi Walk ======================
local InMatch = false
local RandomWalkThread = nil
local function IsInMatch() return Workspace:FindFirstChild("Ball") or Workspace:FindFirstChild("TheBall") end

local function StartRandomWalk()
    if RandomWalkThread then return end
    RandomWalkThread = task.spawn(function()
        while Settings.AutoWalk and InMatch and Character and Humanoid.Health > 0 do
            local randomX = math.random(-70, 70)
            local randomZ = math.random(-70, 70)
            local targetPos = RootPart.Position + Vector3.new(randomX, 5, randomZ)
            local path = PathfindingService:CreatePath({AgentRadius = 3, AgentHeight = 6, AgentCanJump = true})
            path:ComputeAsync(RootPart.Position, targetPos)
            if path.Status == Enum.PathStatus.Success then
                for _, wp in ipairs(path:GetWaypoints()) do
                    if not (Settings.AutoWalk and InMatch) then break end
                    Humanoid:MoveTo(wp.Position)
                    Humanoid.MoveToFinished:Wait(2)
                    if math.random(1,4) == 1 then Humanoid:ChangeState(Enum.HumanoidStateType.Jumping) task.wait(0.3) end
                end
            else
                Humanoid:MoveTo(targetPos) task.wait(math.random(2,4))
            end
            task.wait(math.random(15,35)/10)
        end
    end)
end
local function StopRandomWalk()
    if RandomWalkThread then task.cancel(RandomWalkThread) RandomWalkThread = nil end
    if Humanoid then Humanoid:MoveTo(RootPart.Position) end
end

Workspace.ChildAdded:Connect(function(c) if c.Name == "Ball" or c.Name == "TheBall" then InMatch = true if Settings.AutoWalk then StartRandomWalk() end end end)
Workspace.ChildRemoved:Connect(function(c) if c.Name == "Ball" or c.Name == "TheBall" then InMatch = false StopRandomWalk() end end)

LocalPlayer.CharacterAdded:Connect(function(new) Character = new Humanoid = new:WaitForChild("Humanoid") RootPart = new:WaitForChild("HumanoidRootPart") if InMatch and Settings.AutoWalk then StartRandomWalk() end end)
Humanoid.Died:Connect(function() InMatch = false StopRandomWalk() end)

