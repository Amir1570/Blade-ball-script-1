-- 🖤 Minimal Super Anti Lag for Blade Ball - Mobile Delta 2026
-- خفيف جدًا + تنظيف مرة واحدة فقط (ما يثقلش الهاتف)

local ws = game:GetService("Workspace")
local lighting = game:GetService("Lighting")

print("🖤 Minimal Anti Lag Mobile جاري التفعيل...")

-- 1. إعدادات إضاءة خفيفة للموبايل
lighting.GlobalShadows = false
lighting.ShadowSoftness = 0
lighting.Brightness = 3
lighting.ClockTime = 14
lighting.FogEnd = 999999
lighting.FogStart = 999999
lighting.EnvironmentDiffuseScale = 0
lighting.EnvironmentSpecularScale = 0
lighting.Ambient = Color3.fromRGB(90, 90, 90)

-- 2. تنظيف مرة واحدة فقط (خفيف وسريع)
local function MinimalCleanup()
    for _, obj in pairs(ws:GetDescendants()) do
        if obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Trail") or 
           obj:IsA("Sparkles") or obj:IsA("Smoke") or obj:IsA("Fire") then
            obj.Enabled = false
            obj:Destroy()
        
        elseif obj:IsA("Attachment") then
            for _, child in pairs(obj:GetChildren()) do
                if child:IsA("ParticleEmitter") or child:IsA("Beam") or child:IsA("Trail") then
                    child.Enabled = false
                    child:Destroy()
                end
            end
            obj:Destroy()
        
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            if obj.Parent and not string.find(obj.Parent.Name:lower(), "ball") then
                obj.Transparency = 1
                obj:Destroy()
            end
        
        elseif obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation") then
            local name = obj.Name:lower()
            local parent = obj.Parent and obj.Parent.Name:lower() or ""
            
            if name:find("pillar") or name:find("column") or name:find("rock") or name:find("cabin") or 
               name:find("statue") or name:find("fence") or name:find("building") or name:find("tree") or 
               name:find("mountain") or name:find("deco") or name:find("extra") or name:find("wall") or 
               name:find("platform") or name:find("fallen") or name:find("floating") or name:find("grass") or 
               parent:find("deco") or parent:find("environment") then
                
                if not name:find("floor") and not name:find("ground") and not name:find("arena") and 
                   not name:find("ball") then
                    obj.Transparency = 1
                    obj.CanCollide = false
                    obj.CastShadow = false
                end
            end
            obj.CastShadow = false
            if obj:IsA("MeshPart") then
                obj.RenderFidelity = Enum.RenderFidelity.Performance
            end
        end
    end
end

-- تنفيذ التنظيف مرة واحدة فقط
MinimalCleanup()

-- إعدادات Roblox للموبايل
settings().Rendering.QualityLevel = Enum.QualityLevel.Level01

if ws:FindFirstChild("Terrain") then
    local t = ws.Terrain
    t.WaterWaveSize = 0
    t.WaterWaveSpeed = 0
    t.WaterReflectance = 0
    t.WaterTransparency = 1
end

print("✅ Minimal Anti Lag Mobile مفعل بنجاح!")
print("جرب العب مباراة كاملة ولاحظ الفرق من أول ثانية")
