-- البحث عن أزرار الصد والقدرة تلقائياً --
local function FindRemotes()
    local Remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
    if Remotes then
        ParryRemote = Remotes:FindFirstChild("ParryButtonPress")
        AbilityRemote = Remotes:FindFirstChild("AbilityButtonPress")
    end
end

-- التحقق من أن الكرة تستهدفك --
local function IsTargeted()
    local char = Player.Character
    return char and char:FindFirstChild("Highlight") ~= nil
end

-- تنفيذ الصد --
local function ExecuteParry()
    if ParryRemote then
        pcall(function() ParryRemote:Fire() end)
        pcall(function() ParryRemote:FireServer() end)
    end
end

-- تنفيذ القدرة --
local function ExecuteAbility()
    if AbilityRemote then
        pcall(function() AbilityRemote:Fire() end)
        pcall(function() AbilityRemote:FireServer() end)
    end
end

-- نظام القفز الذكي --
local function SmartJump()
    local char = Player.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum and hum:GetState() == Enum.HumanoidStateType.Landed then
            hum.Jump = true
        end
    end
end

-- نظام تحسين الأداء (Anti-Lag) --
local function OptimizePerformance()
    local Lighting = game:GetService("Lighting")
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    Lighting.FogStart = 9e9
    Lighting.Brightness = 2
    Lighting.ClockTime = 14

    local colorCorrection = Instance.new("ColorCorrectionEffect")
    colorCorrection.Saturation = -1
    colorCorrection.Parent = Lighting

    for _, v in ipairs(workspace:GetDescendants()) do
        pcall(function()
            if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") then
                v.Enabled = false
            end
            if v:IsA("BloomEffect") or v:IsA("BlurEffect") then
                v.Enabled = false
            end
            if v:IsA("BasePart") then
                v.CastShadow = false
            end
        end)
    end
end

-- إعادة ضبط الإعدادات عند الإغلاق --
local function ResetPerformance()
    local Lighting = game:GetService("Lighting")
    Lighting.GlobalShadows = true
    Lighting.FogEnd = 100000
    Lighting.FogStart = 0
    Lighting.Brightness = 1

    for _, v in ipairs(Lighting:GetChildren()) do
        if v:IsA("ColorCorrectionEffect") then
            v:Destroy()
        end
    end
end

