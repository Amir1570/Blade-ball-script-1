Content.Position = UDim2.new(0, 10, 0, 65)
Content.BackgroundTransparency = 1

local TPages = {}
local TBtns = {}

local function MakeTab(name, icon, active)
    local b = Instance.new("TextButton", TabBar)
    b.Size = UDim2.new(0.33, -4, 1, 0)
    b.Text = icon
    b.BackgroundColor3 = active and C.Accent or C.Card
    b.TextColor3 = C.Text
    Instance.new("UICorner", b)

    local p = Instance.new("ScrollingFrame", Content)
    p.Size = UDim2.new(1, 0, 1, 0)
    p.Visible = active
    p.BackgroundTransparency = 1
    p.AutomaticCanvasSize = Enum.AutomaticSize.Y
    p.ScrollBarThickness = 2
    Instance.new("UIListLayout", p).Padding = UDim.new(0, 10)

    TPages[name] = p
    TBtns[name] = b

    b.MouseButton1Click:Connect(function()
        for k, v in pairs(TPages) do
            v.Visible = (k == name)
            TBtns[k].BackgroundColor3 = (k == name) and C.Accent or C.Card
        end
    end)
    return p
end

local P1 = MakeTab("Home", "🏠 الرئيسية", true)
local P2 = MakeTab("Move", "🎮 حركة", false)
local P3 = MakeTab("Perf", "⚡ أداء", false)

-- دالة إضافة Toggle مع دعم الحفظ التلقائي
local function CreateToggle(parent, title, configKey, callback)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(1, 0, 0, 50)
    f.BackgroundColor3 = C.Card
    Instance.new("UICorner", f)

    local l = Instance.new("TextLabel", f)
    l.Text = "  " .. title
    l.Size = UDim2.new(0.7, 0, 1, 0)
    l.TextColor3 = C.Text
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.BackgroundTransparency = 1

    local btn = Instance.new("TextButton", f)
    btn.Size = UDim2.new(0, 50, 0, 25)
    btn.Position = UDim2.new(1, -60, 0.5, -12)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)

    local function updateUI(state)
        btn.Text = state and "ON" or "OFF"
        btn.BackgroundColor3 = state and C.Accent or Color3.fromRGB(60, 60, 75)
    end

    updateUI(Settings[configKey]) -- ضبط الحالة عند التحميل

    btn.MouseButton1Click:Connect(function()
        Settings[configKey] = not Settings[configKey]
        updateUI(Settings[configKey])
        SaveSettings() -- حفظ التغيير فوراً
        callback(Settings[configKey])
    end)
end

