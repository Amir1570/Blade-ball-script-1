local Dirs = {
    Vector3.new(1,0,0),  Vector3.new(-1,0,0),
    Vector3.new(0,0,1),  Vector3.new(0,0,-1),
    Vector3.new(1,0,1).Unit, Vector3.new(-1,0,-1).Unit,
    Vector3.new(1,0,-1).Unit, Vector3.new(-1,0,1).Unit,
}

local lastJump   = 0
local lastWalk   = 0
local lastRandom = 0

-- ══════════════════════════════════════════════
-- دالة للتحقق من أن الكرة قريبة وتستهدفك
-- ══════════════════════════════════════════════
local function IsBallTargetingMe()
    local char = LP.Character
    if not char then return false end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- الطريقة 1: التحقق من Highlight (الأكثر دقة)
    if char:FindFirstChild("Highlight") then
        return true
    end
    
    -- الطريقة 2: التحقق من وجود كرة قريبة وسريعة
    if Balls then
        for _, ball in ipairs(Balls:GetChildren()) do
            if ball:IsA("BasePart") then
                local dist = (hrp.Position - ball.Position).Magnitude
                local vel = ball.AssemblyLinearVelocity
                -- إذا كانت الكرة قريبة (أقل من 20) وتتحرك بسرعة نحوي
                if dist < 20 and vel.Magnitude > 10 then
                    local dirToPlayer = (hrp.Position - ball.Position).Unit
                    local velDir = vel.Unit
                    local dot = dirToPlayer:Dot(velDir)
                    if dot > 0.7 then -- تتجه نحوي
                        return true
                    end
                end
            end
        end
    end
    
    return false
end

