local function Row(p, h)
    local f = Instance.new("Frame", p)
    f.Size = UDim2.new(1, 0, 0, h)
    f.BackgroundColor3 = C.Card
    f.BorderSizePixel = 0
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 10)
    return f
end

-- إنشاء الأزرار بالتصميم المطلوب
local function CreateBtn(p, txt, callback)
    local b = Row(p, 50)
    local layout = Instance.new("UIPadding", b)
    layout.PaddingLeft = UDim.new(0, 10)
    layout.PaddingRight = UDim.new(0, 10)

    local tl = Instance.new("TextLabel", b)
    tl.Size = UDim2.new(0.65, 0, 1, 0)
    tl.Text = txt
    tl.TextColor3 = C.Text
    tl.Font = Enum.Font.GothamBold
    tl.TextSize = 12
    tl.TextXAlignment = Enum.TextXAlignment.Left
    tl.BackgroundTransparency = 1

    local t = Instance.new("TextButton", b)
    t.Size = UDim2.new(0.3, 0, 0.6, 0)
    t.Position = UDim2.new(0.7, 0, 0.2, 0)
    t.BackgroundColor3 = C.BG
    t.Text = "OFF"
    t.TextColor3 = C.Accent
    t.Font = Enum.Font.GothamBold
    Instance.new("UICorner", t).CornerRadius = UDim.new(0, 6)

    local state = false
    t.MouseButton1Click:Connect(function()
        state = not state
        callback(state)
        t.Text = state and "ON" or "OFF"
        t.BackgroundColor3 = state and C.Accent or C.BG
        t.TextColor3 = state and Color3.new(1,1,1) or C.Accent
    end)
end

