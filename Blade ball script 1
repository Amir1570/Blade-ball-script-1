-- ====================== إعدادات ======================
local SettingsFile = "BladeBall_Raw_v7_1.json"
local Settings = {
    AutoWalk     = true,
    DoubleJump   = true,
    UltraAntiLag = true,
    AutoParry    = true,
    AutoAbility  = true,
    RadialField  = true,
}

local function LoadSettings()
    if isfile and isfile(SettingsFile) then
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(SettingsFile)) end)
        if ok then Settings = data end
    end
end
local function SaveSettings()
    if writefile then
        pcall(function() writefile(SettingsFile, HttpService:JSONEncode(Settings)) end)
    end
end
