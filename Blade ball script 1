-- ====================== Levi Walk ======================
local InMatch = false
local RandomWalkThread = nil

local function IsInMatch()
    return Workspace:FindFirstChild("Ball") or Workspace:FindFirstChild("TheBall")
end

local function StartRandomWalk()
    if RandomWalkThread then return end
    RandomWalkThread = task.spawn(function()
        while Settings.AutoWalk and InMatch and Character and Humanoid.Health > 0 do
            local rx = math.random(-70, 70)
            local rz = math.random(-70, 70)
            local target = RootPart.Position + Vector3.new(rx, 5, rz)
            local path = PathfindingService:CreatePath({AgentRadius=3, AgentHeight=6, AgentCanJump=true})
            path:ComputeAsync(RootPart.Position, target)
            if path.Status == Enum.PathStatus.Success then
                for _, wp in ipairs(path:GetWaypoints()) do
                    if not (Settings.AutoWalk and InMatch) then break end
                    Humanoid:MoveTo(wp.Position)
                    Humanoid.MoveToFinished:Wait(2)
                    if math.random(1,4) == 1 then
                        Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                        task.wait(0.3)
                    end
                end
            else
                Humanoid:MoveTo(target)
                task.wait(math.random(2,4))
            end
            task.wait(math.random(1.5, 3.5))
        end
    end)
end

local function StopRandomWalk()
    if RandomWalkThread then task.cancel(RandomWalkThread) RandomWalkThread = nil end
    if Humanoid then Humanoid:MoveTo(RootPart.Position) end
end

Workspace.ChildAdded:Connect(function(c)
    if c.Name == "Ball" or c.Name == "TheBall" then
        InMatch = true
        if Settings.AutoWalk then StartRandomWalk() end
    end
end)
Workspace.ChildRemoved:Connect(function(c)
    if c.Name == "Ball" or c.Name == "TheBall" then
        InMatch = false; StopRandomWalk()
    end
end)

-- ====================== Auto Parry ======================
local ParryRemote, AbilityRemote
local parryRunning = false
local parryThread  = nil

pcall(function()
    local R = ReplicatedStorage:FindFirstChild("Remotes")
    if R then
        ParryRemote   = R:FindFirstChild("ParryButtonPress") or R:FindFirstChild("Parry")
        AbilityRemote = R:FindFirstChild("AbilityButtonPress") or R:FindFirstChild("Ability")
    end
end)

local function StartSmartAutoParry()
    if parryRunning then return end
    parryRunning = true
    parryThread = task.spawn(function()
        while parryRunning do
            pcall(function()
                if not Settings.AutoParry then return end
                local char = LocalPlayer.Character
                if not char then return end
                if char:FindFirstChild("Highlight") then
                    if ParryRemote   then pcall(function() ParryRemote:FireServer()   end) end
                    if Settings.AutoAbility and AbilityRemote then
                        pcall(function() AbilityRemote:FireServer() end)
                    end
                end
            end)
            task.wait(0.15)
        end
    end)
end

local function StopSmartAutoParry()
    parryRunning = false
    if parryThread then pcall(function() task.cancel(parryThread) end); parryThread = nil end
end

-- ====================== Ultra Anti-Lag ======================
local function ActivateUltraAntiLag()
    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9; Lighting.FogStart = 9e9; Lighting.Brightness = 2
        if not Lighting:FindFirstChild("BB_CC") then
            local cc = Instance.new("ColorCorrectionEffect")
            cc.Name = "BB_CC"; cc.Saturation = -1; cc.Parent = Lighting
        end
        for _, v in ipairs(workspace:GetDescendants()) do
            pcall(function()
                if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke")
                or v:IsA("Fire") or v:IsA("Sparkles") then v.Enabled = false end
                if v:IsA("BloomEffect") or v:IsA("BlurEffect")
                or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") then v.Enabled = false end
                if v:IsA("BasePart") then v.CastShadow = false end
            end)
        end
    end)
end

