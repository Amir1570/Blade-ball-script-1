-- [2] دالة ذكية جداً للتحقق من المباراة
-- تعتمد على وجود "واجهة الصد" (Block Button) التي لا تظهر إلا في المباراة
local function IsInMatch()
    local playerGui = LP:FindFirstChild("PlayerGui")
    if playerGui then
        -- البحث عن أي واجهة تحتوي على كلمة "Block" أو "Ability" وهي موجودة فقط في الملعب
        local screenUI = playerGui:FindFirstChild("Hotbar") or playerGui:FindFirstChild("AbilityGui")
        if screenUI and screenUI.Enabled then
            return true
        end
    end
    return false
end

