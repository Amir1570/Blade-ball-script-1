-- Main Loop
-- ══════════════════════════════════════════════
local lastJump = 0
local lastWalk = 0
local lastRandom = 0
local lastAbility = 0

RunService.Heartbeat:Connect(function()
    pcall(function()
        local char = LP.Character
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        
        local now = tick()
        local inGame = IsInGame()
        
        -- Auto Parry
        if CFG.AutoParry and ParryRE and Balls then
            for _, ball in ipairs(Balls:GetChildren()) do
                if ball:IsA("BasePart") and (ball:GetAttribute("realBall") == true or ball.Name:find("Ball")) then
                    -- توجيه الشخصية نحو الكرة
                    hrp.CFrame = CFrame.new(hrp.Position, ball.Position)
                    
                    -- التحقق من Highlight أو أي مؤشر أن الكرة تستهدفك
                    if char:FindFirstChild("Highlight") or char:FindFirstChild("Targeted") then
                        pcall(function() ParryRE:FireServer() end)
                        pcall(function() ParryRE:Fire() end)
                        AddLog("🛡 تم الصد بنجاح", C.Green)
                    end
                    break
                end
            end
        end
        
        -- Auto Ability
        if CFG.AutoAbility and AbilityRE and Balls and now - lastAbility > 2 then
            for _, ball in ipairs(Balls:GetChildren()) do
                if ball:IsA("BasePart") and (ball:GetAttribute("realBall") == true or ball.Name:find("Ball")) then
                    if char:FindFirstChild("Highlight") or char:FindFirstChild("Targeted") then
                        lastAbility = now
                        pcall(function() AbilityRE:FireServer() end)
                        pcall(function() AbilityRE:Fire() end)
                        AddLog("✨ تم استخدام القدرة", C.Yellow)
                    end
                    break
                end
            end
        end
        
        -- Auto Jump (يعمل في كل مكان)
        if CFG.AutoJump and now - lastJump >= CFG.JumpInterval then
            lastJump = now
            hum.Jump = true
        end
        
        -- الحركة فقط داخل الساحة
        if inGame then
            -- Auto Walk
            if CFG.AutoWalk and now - lastWalk >= 0.6 then
                lastWalk = now
                local targetPos = hrp.Position + directions[math.random(1,#directions)] * 22
                hum:MoveTo(targetPos)
            end
            
            -- Random Move
            if CFG.RandomMove and now - lastRandom >= CFG.MoveInterval then
                lastRandom = now
                local targetPos = hrp.Position + directions[math.random(1,#directions)] * 18
                hum:MoveTo(targetPos)
            end
        end
    end)
end)

