local function MakeTab(name, icon, order)
    local Btn = Instance.new("TextButton")
    Btn.Text            = icon
    Btn.Font            = Enum.Font.GothamBold
    Btn.TextSize        = 13
    Btn.TextColor3      = C.Muted
    Btn.BackgroundColor3 = Color3.fromRGB(14, 14, 22)
    Btn.Size            = UDim2.new(0.25, -2, 1, 0)
    Btn.BorderSizePixel = 0
    Btn.LayoutOrder     = order
    Btn.ZIndex          = 7
    Btn.Parent          = TabBar
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)

    -- tooltip
    local tip = Instance.new("TextLabel")
    tip.Text           = name
    tip.Font           = Enum.Font.Gotham
    tip.TextSize       = 8
    tip.TextColor3     = C.Muted
    tip.BackgroundTransparency = 1
    tip.Size           = UDim2.new(1, 0, 0, 10)
    tip.Position       = UDim2.new(0, 0, 1, -10)
    tip.TextXAlignment = Enum.TextXAlignment.Center
    tip.ZIndex         = 8
    tip.Parent         = Btn

    local Page = Instance.new("ScrollingFrame")
    Page.Size                = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.BorderSizePixel     = 0
    Page.ScrollBarThickness  = 2
    Page.ScrollBarImageColor3 = C.Accent
    Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Page.CanvasSize          = UDim2.new(0, 0, 0, 0)
    Page.Visible             = false
    Page.ZIndex              = 7
    Page.Parent              = Content

    local PL = Instance.new("UIListLayout")
    PL.SortOrder = Enum.SortOrder.LayoutOrder
    PL.Padding   = UDim.new(0, 5)
    PL.Parent    = Page

    local PP = Instance.new("UIPadding")
    PP.PaddingTop    = UDim.new(0, 4)
    PP.PaddingBottom = UDim.new(0, 8)
    PP.Parent        = Page

    TBtns[name]  = Btn
    TPages[name] = Page

    Btn.MouseButton1Click:Connect(function()
        if ActiveTab == name then return end
        if ActiveTab then
            TPages[ActiveTab].Visible = false
            TweenService:Create(TBtns[ActiveTab], TweenInfo.new(0.12), {
                BackgroundColor3 = Color3.fromRGB(14, 14, 22),
                TextColor3       = C.Muted,
            }):Play()
        end
        ActiveTab = name
        Page.Visible = true
        TweenService:Create(Btn, TweenInfo.new(0.12), {
            BackgroundColor3 = C.Accent,
            TextColor3       = Color3.fromRGB(255, 255, 255),
        }):Play()
    end)

    return Page
end

