-- ══════════════════════════════════════════════
-- دالة محسنة للتحقق من وجود اللاعب في الساحة
-- ══════════════════════════════════════════════
local function IsInGame()
    -- تحديث كل 0.5 ثانية فقط لتوفير الأداء
    local now = tick()
    if now - lastGameCheck < 0.5 then
        return isInGameCache
    end
    lastGameCheck = now
    
    -- التحقق من وجود أي من أسماء الساحة
    for _, name in ipairs(ArenaNames) do
        if Workspace:FindFirstChild(name) then
            isInGameCache = true
            return true
        end
    end
    
    -- التحقق من وجود الكرة في الساحة (علامة قوية)
    if Balls and #Balls:GetChildren() > 0 then
        isInGameCache = true
        return true
    end
    
    -- التحقق من وجود لاعبين آخرين في المنطقة
    local char = LP.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local hrp = char.HumanoidRootPart
        local nearbyPlayers = 0
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LP and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (hrp.Position - player.Character.HumanoidRootPart.Position).Magnitude
                if dist < 100 then
                    nearbyPlayers = nearbyPlayers + 1
                end
            end
        end
        if nearbyPlayers > 0 then
            isInGameCache = true
            return true
        end
    end
    
    isInGameCache = false
    return false
end

-- ══════════════════════════════════════════════
-- دالة محسنة للتحقق مما إذا كانت الكرة تستهدف اللاعب
-- ══════════════════════════════════════════════
local function IsBallTargetingMe()
    local char = LP.Character
    if not char then return false end
    
    -- الطريقة الأساسية: التحقق من Highlight
    if char:FindFirstChild("Highlight") then
        return true
    end
    
    -- طريقة احتياطية: التحقق من وجود كرة متجهة نحوي
    if Balls then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            for _, ball in ipairs(Balls:GetChildren()) do
                if ball:IsA("BasePart") and ball:GetAttribute("realBall") == true then
                    -- التحقق من اتجاه الكرة
                    local vel = ball.AssemblyLinearVelocity
                    local dirToPlayer = (hrp.Position - ball.Position).Unit
                    local velDir = vel.Unit
                    local dot = dirToPlayer:Dot(velDir)
                    
                    -- إذا كانت الكرة تتجه نحوي بزاوية أقل من 30 درجة
                    if dot > 0.86 then  -- cos(30°)
                        return true
                    end
                end
            end
        end
    end
    
    return false
end

-- ══════════════════════════════════════════════
-- دالة لإيقاف الحركة فوراً
-- ══════════════════════════════════════════════
local function StopMovement(hum)
    if hum and hum:IsA("Humanoid") then
        hum:MoveTo(hum.Parent and hum.Parent:FindFirstChild("HumanoidRootPart") and hum.Parent.HumanoidRootPart.Position or hum.Parent.PrimaryPart.Position)
        hum:Move(Vector3.new(0,0,0))
        isMoving = false
        currentWalkTarget = nil
    end
end

