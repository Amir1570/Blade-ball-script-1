-- MAIN LOOP
-- ══════════════════════════════════════════════
local lastJump   = 0
local lastWalk   = 0
local lastRandom = 0
local Dirs = {
    Vector3.new(1,0,0),  Vector3.new(-1,0,0),
    Vector3.new(0,0,1),  Vector3.new(0,0,-1),
    Vector3.new(1,0,1).Unit, Vector3.new(-1,0,-1).Unit,
    Vector3.new(1,0,-1).Unit, Vector3.new(-1,0,1).Unit,
}

RunService.Heartbeat:Connect(function()
    pcall(function()
        local char = LP.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        local now = tick()

        if CFG.AutoParry  then TryParry() end

        if CFG.AutoJump and now - lastJump >= CFG.JumpInterval then
            lastJump = now
            hum.Jump = true
        end

        if CFG.AutoWalk and now - lastWalk >= 0.5 then
            lastWalk = now
            hum:MoveTo(hrp.Position + Dirs[math.random(1,#Dirs)] * 22)
        end

        if CFG.RandomMove and now - lastRandom >= CFG.MoveInterval then
            lastRandom = now
            hum:MoveTo(hrp.Position + Dirs[math.random(1,#Dirs)] * 16)
        end
    end)
end)

