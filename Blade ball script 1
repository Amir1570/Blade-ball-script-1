-- FPS Counter (محسن)
-- ══════════════════════════════════════════════
local frameTimes = {}
local lastFrame = tick()

RunService.RenderStepped:Connect(function()
    local now = tick()
    local dt = now - lastFrame
    lastFrame = now
    
    if dt > 0 then
        table.insert(frameTimes, 1/dt)
        if #frameTimes > 30 then table.remove(frameTimes, 1) end
        
        local sum = 0
        for _, v in ipairs(frameTimes) do sum = sum + v end
        local avg = math.floor(sum / #frameTimes)
        
        local color = avg >= 50 and C.Green or avg >= 25 and C.Yellow or C.Red
        fpsLbl.Text = "⚡ FPS: "..avg
        fpsLbl.TextColor3 = color
        perfLbl.Text = "⚡ FPS: "..avg
        perfLbl.TextColor3 = color
    end
end)

