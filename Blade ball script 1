-- Smooth Black Anti Lag + Auto Cleanup for Blade Ball
-- تنظيف سلس + حذف المؤثرات الثقيلة + أجزاء الحلبة

local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

print("🖤 Smooth Black Anti Lag جاري التفعيل...")

-- إعدادات الإضاءة للسلاسة
Lighting.GlobalShadows = false
Lighting.ShadowSoftness = 0
Lighting.Brightness = 2.5
Lighting.ClockTime = 14
Lighting.FogEnd = 999999
Lighting.FogStart = 999999
Lighting.EnvironmentDiffuseScale = 0
Lighting.EnvironmentSpecularScale = 0

local function SmoothBlackCleanup()
    for _, v in pairs(Workspace:GetDescendants()) do
        -- تنظيف كل المؤثرات البصرية
        if v:IsA("ParticleEmitter") or v:IsA("Beam") or v:IsA("Trail") or v:IsA("Sparkles") or v:IsA("Smoke") or v:IsA("Fire") then
            v.Enabled = false
            pcall(function() v:Destroy() end)
        
        -- تنظيف الـ Attachments المرتبطة بالمؤثرات
        elseif v:IsA("Attachment") then
            if v:FindFirstChildOfClass("ParticleEmitter") or v:FindFirstChildOfClass("Beam") or v:FindFirstChildOfClass("Trail") then
                pcall(function() v:Destroy() end)
            end
        
        -- إخفاء الديكورات والTextures
        elseif v:IsA("Decal") or v:IsA("Texture") then
            if v.Parent and not v.Parent.Name:lower():find("ball") then
                v.Transparency = 1
                pcall(function() v:Destroy() end)
            end
        
        -- إخفاء الأجزاء الثقيلة في الحلبة
        elseif v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("UnionOperation") then
            local name = v.Name:lower()
            if name:find("pillar") or name:find("column") or name:find("rock") or name:find("deco") or name:find("statue") or 
               name:find("fence") or name:find("building") or name:find("tree") or name:find("mountain") or name:find("extra") then
                v.Transparency = 1
                v.CanCollide = false
                v.CastShadow = false
            end
            v.CastShadow = false
            if v:IsA("MeshPart") then
                v.RenderFidelity = Enum.RenderFidelity.Performance
            end
        end
    end
end

-- تنظيف أولي
SmoothBlackCleanup()

-- تنظيف مستمر سلس كل 1.5 ثانية (هذا هو الجزء المهم في Smooth Black)
task.spawn(function()
    while true do
        SmoothBlackCleanup()
        task.wait(1.5)   -- يمكن تغييره إلى 1 لتنظيف أسرع أو 2 لتوفير أكثر
    end
end)

-- إعدادات إضافية للسلاسة
settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
if workspace:FindFirstChild("Terrain") then
    workspace.Terrain.WaterWaveSize = 0
    workspace.Terrain.WaterWaveSpeed = 0
    workspace.Terrain.WaterReflectance = 0
    workspace.Terrain.WaterTransparency = 1
end

print("✅ Smooth Black Anti Lag مفعل بنجاح!")
print("اللعبة الآن تنظف نفسها تلقائياً كل 1.5 ثانية → FPS أعلى وسلاسة أفضل")
