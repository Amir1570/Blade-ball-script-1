-- Toggle Function
local function AddToggle(parent, text, key)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(1, 0, 0, 45); f.BackgroundColor3 = Color3.fromRGB(25, 25, 35); Instance.new("UICorner", f)
    local lbl = Instance.new("TextLabel", f); lbl.Text = "  "..text; lbl.Size = UDim2.new(0.7,0,1,0); lbl.TextColor3 = Color3.new(1,1,1); lbl.BackgroundTransparency = 1; lbl.TextXAlignment = Enum.TextXAlignment.Left
    local btn = Instance.new("TextButton", f); btn.Size = UDim2.new(0, 50, 0, 25); btn.Position = UDim2.new(1, -60, 0.5, -12); Instance.new("UICorner", btn)
    local function up() btn.Text = CFG[key] and "ON" or "OFF"; btn.BackgroundColor3 = CFG[key] and Color3.fromRGB(99, 102, 241) or Color3.fromRGB(50,50,60) end
    up(); btn.MouseButton1Click:Connect(function() CFG[key] = not CFG[key]; up(); Save() end)
end

