-- الإصلاح 1: IsInRealGame محسّنة
-- تتحقق من وجود كرة تتحرك فعلاً = مباراة حقيقية
-- في اللوبي الكرات إما غير موجودة أو ساكنة
-- ══════════════════════════════════════════════
local function IsInRealGame()
    -- الشرط الأساسي: اللاعب نفسه يجب أن يكون حياً
    local char = LP.Character
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end

    -- تحقق من GameTimer
    if workspace:FindFirstChild("GameTimer") then return true end
    if workspace:FindFirstChild("RoundTimer") then return true end
    if workspace:FindFirstChild("MatchTimer") then return true end

    -- تحقق من كرة تتحرك فعلاً
    if Balls then
        for _, ball in ipairs(Balls:GetChildren()) do
            if ball:IsA("BasePart") and ball:GetAttribute("realBall") == true then
                if ball.AssemblyLinearVelocity.Magnitude > 15 then
                    return true
                end
            end
        end
    end

    return false
end

