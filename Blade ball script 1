-- Blade Ball Script from Scratch

-- Save Data to File
local saveData = {}
local saveFile = "saveData.txt"

function saveDataToFile()
    local file = io.open(saveFile, "w")
    if file then
        file:write(json.encode(saveData))
        file:close()
    end
end

function loadDataFromFile()
    local file = io.open(saveFile, "r")
    if file then
        saveData = json.decode(file:read("*a"))
        file:close()
    end
end

-- Load Save Data
loadDataFromFile()

-- Random Walking
local player = {
    x = 0,
    y = 0,
    speed = 5,
    jumpSpeed = 10,
    gravity = 0.5,
    isJumping = false,
    isalog = false,
    isDead = false,
    isRunning = false,
}

function player:jump()
    if not self.isJumping and not self.isDead then
        self.isJumping = true
        self.vy = -self.jumpSpeed
    end
end

function player:update(dt)
    if not self.isDead then
        if self.isJumping then
            self.vy = self.vy + self.gravity * dt
            self.y = self.y + self.vy * dt
            if self.y >= 100 then
                self.isJumping = false
                self.y = 100
            end
        end
        if self.isRunning then
            self.x = self.x + self.speed * dt
        end
    end
end

-- Otto Two Jumps
local otto = {
    x = 0,
    y = 0,
    speed = 5,
    jumpSpeed = 10,
    gravity = 0.5,
    isJumping = false,
    isalog = false,
    isDead = false,
    isRunning = false,
    jumpCount = 0,
}

function otto:jump()
    if not self.isJumping and not self.isDead then
        self.isJumping = true
        self.vy = -self.jumpSpeed
        self.jumpCount = self.jumpCount + 1
        if self.jumpCount == 2 then
            self.isalog = true
        end
    end
end

function otto:update(dt)
    if not self.isDead then
        if self.isJumping then
            self.vy = self.vy + self.gravity * dt
            self.y = self.y + self.vy * dt
            if self.y >= 100 then
                self.isJumping = false
                self.y = 100
            end
        end
        if self.isRunning then
            self.x = self.x + self.speed * dt
        end
    end
end

-- Super Anti Lag Magic
function update(dt)
    player:update(dt)
    otto:update(dt)
    if player.isJumping then
        player.isalog = true
    end
    if otto.isJumping then
        otto.isalog = true
    end
end

-- Close Script Button and Minimize User Interface
function closeScript()
    saveDataToFile()
    os.execute("taskkill /im lua.exe")
end

function minimizeUI()
    os.execute("taskkill /im lua.exe")
    os.execute("start lua.exe")
end

-- Phone UI
function phoneUI()
    print("Phone UI")
    print("1. Close Script")
    print("2. Minimize UI")
    print("3. Save Data")
    local choice = io.read()
    if choice == "1" then
        closeScript()
    elseif choice == "2" then
        minimizeUI()
    elseif choice == "3" then
        saveDataToFile()
    end
end

-- Main Loop
function love.update(dt)
    update(dt)
end

function love.draw()
    -- Draw player and otto
    love.graphics.print("Player: " .. player.x .. ", " .. player.y, 10, 10)
    love.graphics.print("Otto: " .. otto.x .. ", " .. otto.y, 10, 20)
    -- Draw UI
    phoneUI()
end

function love.keypressed(key)
    if key == "space" then
        player:jump()
    elseif key == "r" then
        otto:jump()
    elseif key == "escape" then
        closeScript()
    end
end
