RadialStroke.Transparency = 0.35
RadialStroke.Parent = RadialFrame

local function UpdateRadialField()
    if not Settings.RadialField then
        RadialStroke.Color = Color3.fromRGB(80, 80, 80); return
    end
    local ball = Workspace:FindFirstChild("Ball") or Workspace:FindFirstChild("TheBall")
    if not ball or not RootPart then
        RadialStroke.Color = Color3.fromRGB(100, 100, 100)
        RadialFrame.Size = UDim2.new(0, 380, 0, 380); return
    end
    local dist  = (ball.Position - RootPart.Position).Magnitude
    local speed = ball.Velocity.Magnitude
    if dist < 25 and speed > 18 then
        RadialStroke.Color = Color3.fromRGB(0, 255, 80)
        RadialFrame.Size   = UDim2.new(0, 460, 0, 460)
    elseif dist < 35 then
        RadialStroke.Color = Color3.fromRGB(255, 200, 0)
        RadialFrame.Size   = UDim2.new(0, 410, 0, 410)
    else
        RadialStroke.Color = Color3.fromRGB(255, 50, 50)
        RadialFrame.Size   = UDim2.new(0, 380, 0, 380)
    end
end

RunService.RenderStepped:Connect(UpdateRadialField)

