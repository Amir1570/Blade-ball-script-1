MakeToggle(P_Perf, "⚡  Super Anti-Lag", "يحذف التأثيرات ويستهدف 60 FPS", 3, function(on)
    CFG.AntiLag = on
    pcall(function()
        if on then
            -- إيقاف الظلال والضباب
            Lighting.GlobalShadows      = false
            Lighting.FogEnd             = 9e8
            Lighting.FogStart           = 9e8
            Lighting.Brightness         = 2
            Lighting.ClockTime          = 14

            -- حذف جميع التأثيرات البصرية
            for _, v in ipairs(workspace:GetDescendants()) do
                pcall(function()
                    if v:IsA("ParticleEmitter") or v:IsA("Trail")
                    or v:IsA("Smoke")           or v:IsA("Fire")
                    or v:IsA("Sparkles")        or v:IsA("SelectionBox")
                    or v:IsA("BillboardGui") then
                        v.Enabled = false
                    end
                    if v:IsA("SpecialMesh") then
                        -- keep mesh but reduce
                    end
                    if v:IsA("Decal") or v:IsA("Texture") then
                        v.Transparency = 1
                    end
                    if v:IsA("Sky") then
                        v.Parent = nil
                    end
                    if v:IsA("PostEffect") or v:IsA("BlurEffect")
                    or v:IsA("ColorCorrectionEffect")
                    or v:IsA("DepthOfFieldEffect")
                    or v:IsA("SunRaysEffect")
                    or v:IsA("BloomEffect") then
                        v.Enabled = false
                    end
                end)
            end

            -- تقليل جودة الرسم
            pcall(function()
                settings().Rendering.QualityLevel = 1
            end)
            pcall(function()
                UserSettings():GetService("UserGameSettings").SavedQualityLevel
                    = Enum.SavedQualitySetting.QualityLevel1
            end)

            SetStatus("Anti-Lag نشط ⚡", COL.Yellow)
        else
