local ActiveTab = nil
local TabBtns   = {}
local TabPages  = {}

local function MakeTab(name, icon, order)
    local Btn = Instance.new("TextButton")
    Btn.Text            = icon .. " " .. name
    Btn.Font            = Enum.Font.GothamBold
    Btn.TextSize        = 10
    Btn.TextColor3      = COL.Muted
    Btn.BackgroundColor3 = Color3.fromRGB(16, 16, 25)
    Btn.Size            = UDim2.new(0.25, -2, 1, 0)
    Btn.BorderSizePixel = 0
    Btn.LayoutOrder     = order
    Btn.ZIndex          = 7
    Btn.Parent          = TabBar
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)

    local Page = Instance.new("ScrollingFrame")
    Page.Size                = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.BorderSizePixel     = 0
    Page.ScrollBarThickness  = 2
    Page.ScrollBarImageColor3 = COL.Accent
    Page.CanvasSize          = UDim2.new(0, 0, 0, 0)
    Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
    Page.Visible             = false
    Page.ZIndex              = 7
    Page.Parent              = ScrollArea

    local PLayout = Instance.new("UIListLayout")
    PLayout.SortOrder = Enum.SortOrder.LayoutOrder
    PLayout.Padding   = UDim.new(0, 6)
    PLayout.Parent    = Page

    local PPad = Instance.new("UIPadding")
    PPad.PaddingTop    = UDim.new(0, 4)
    PPad.PaddingBottom = UDim.new(0, 8)
    PPad.Parent        = Page

    TabBtns[name]  = Btn
    TabPages[name] = Page

    Btn.MouseButton1Click:Connect(function()
        if ActiveTab == name then return end
        if ActiveTab then
            TabPages[ActiveTab].Visible = false
            TweenService:Create(TabBtns[ActiveTab], TweenInfo.new(0.15), {
                BackgroundColor3 = Color3.fromRGB(16, 16, 25),
                TextColor3       = COL.Muted,
            }):Play()
        end
        ActiveTab = name
        Page.Visible = true
        TweenService:Create(Btn, TweenInfo.new(0.15), {
            BackgroundColor3 = COL.Accent,
            TextColor3       = Color3.fromRGB(255, 255, 255),
        }):Play()
    end)

    return Page
end

