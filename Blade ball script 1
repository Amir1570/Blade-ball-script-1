-- سحب الـ Floating Tab
local ftDrag = false
local ftStartPos, ftStartInput
FloatingTab.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch
    or inp.UserInputType == Enum.UserInputType.MouseButton1 then
        ftDrag = true
        ftStartPos   = FloatingTab.Position
        ftStartInput = inp.Position
    end
end)
FloatingTab.InputEnded:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.Touch
    or inp.UserInputType == Enum.UserInputType.MouseButton1 then
        -- إذا لم يتحرك كثيراً = ضغطة
        if ftStartInput then
            local delta = (inp.Position - ftStartInput).Magnitude
            if delta < 10 then
                MainPanel.Visible = not MainPanel.Visible
            end
        end
        ftDrag = false
    end
end)
UserInputService.InputChanged:Connect(function(inp)
    if ftDrag and (inp.UserInputType == Enum.UserInputType.Touch
    or inp.UserInputType == Enum.UserInputType.MouseMovement) then
        local delta = inp.Position - ftStartInput
        FloatingTab.Position = UDim2.new(
            ftStartPos.X.Scale, ftStartPos.X.Offset + delta.X,
            ftStartPos.Y.Scale, ftStartPos.Y.Offset + delta.Y
        )
    end
end)

-- ====================== سحب النافذة ======================
do
    local drag, sp, sw
    TitleBar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            drag=true; sp=i.Position; sw=MainPanel.Position
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then drag=false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if not drag then return end
        if i.UserInputType ~= Enum.UserInputType.MouseMovement
        and i.UserInputType ~= Enum.UserInputType.Touch then return end
        local d = i.Position - sp
        if d.Magnitude > 5 then
            MainPanel.Position = UDim2.new(
                sw.X.Scale, sw.X.Offset+d.X,
                sw.Y.Scale, sw.Y.Offset+d.Y
            )
        end
    end)
end

