MakeBtn("Anti-Lag",    5, function(on)
    CFG.AntiLag = on
    if on then
        if antiLagConnection then antiLagConnection:Disconnect() end
        if ColorCorrection then ColorCorrection:Destroy() end
        ColorCorrection = Instance.new("ColorCorrectionEffect")
        ColorCorrection.Saturation = -1; ColorCorrection.Parent = Lighting
        Lighting.GlobalShadows = false; Lighting.FogEnd = 9e9
        Lighting.FogStart = 9e9; Lighting.Brightness = 2
        ApplyAntiLag()
        antiLagConnection = RunService.Stepped:Connect(function()
            if not CFG.AntiLag then return end
            task.wait(5); ApplyAntiLag()
        end)
    else
        if antiLagConnection then antiLagConnection:Disconnect() end
        antiLagConnection = nil
        if ColorCorrection then ColorCorrection:Destroy() end
        ColorCorrection = nil
        Lighting.GlobalShadows = true; Lighting.FogEnd = 100000
        Lighting.FogStart = 0; Lighting.Brightness = 1
    end
end)

-- FPS Counter
local fT, fS = 0, {}
RunService.Heartbeat:Connect(function(dt)
    table.insert(fS, 1/math.max(dt,0.001))
    if #fS > 30 then table.remove(fS,1) end
    fT += dt
    if fT >= 0.5 then
        fT = 0; local s = 0
        for _, v in ipairs(fS) do s += v end
        local avg = math.floor(s/#fS)
        FpsLbl.Text = "⚡ FPS: "..avg
        FpsLbl.TextColor3 = avg>=50 and C.BtnOn or avg>=25 and C.Yellow or C.Red
    end
end)

