game:GetService("RunService").Heartbeat:Connect(function()
    pcall(function()
        local character = Player.Character
        if not character then return end
        
        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
        local humanoid = character:FindFirstChild("Humanoid")
        if not humanoidRootPart or not humanoid then return end
        
        local now = tick()
        local isTargeted = IsTargeted()
        
        -- التصدي التلقائي --
        if Settings.AutoParry and isTargeted and now - Cooldowns.Parry >= 0.3 then
            Cooldowns.Parry = now
            ExecuteParry()
        end
        
        -- القدرة التلقائية --
        if Settings.AutoAbility and isTargeted and now - Cooldowns.Ability >= 1.5 then
            Cooldowns.Ability = now
            ExecuteAbility()
        end
        
        -- القفز التلقائي --
        if Settings.AutoJump and isTargeted and now - Cooldowns.Jump >= 0.4 then
            Cooldowns.Jump = now
            SmartJump()
        end
        
        -- الحركة --
        local canMove = isTargeted and (Settings.AutoWalk or Settings.RandomMove)
        
        if canMove then
            if Settings.AutoWalk and now - Cooldowns.Walk >= 0.6 then
                Cooldowns.Walk = now
                local targetPos = humanoidRootPart.Position + Directions[math.random(1, #Directions)] * 22
                humanoid:MoveTo(targetPos)
            elseif Settings.RandomMove and now - Cooldowns.Random >= Settings.MoveDelay then
                Cooldowns.Random = now
                local targetPos = humanoidRootPart.Position + Directions[math.random(1, #Directions)] * 16
                humanoid:MoveTo(targetPos)
            end
        end
    end)
end)

