-- ✅ IsInRealGame - إصلاح المشي بعد الموت (Y position)
-- ══════════════════════════════════════════════
local function IsInRealGame()
    local char = LP.Character
    if not char then return false end
    
    local hum = char:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- ✅ منطقة اللوبي تكون تحت الخريطة (Y منخفض)
    if hrp.Position.Y < -50 then 
        return false 
    end
    
    if Balls then
        for _, ball in ipairs(Balls:GetChildren()) do
            if ball:IsA("BasePart") and ball:GetAttribute("realBall") == true then
                if ball.AssemblyLinearVelocity.Magnitude > 10 then
                    return true
                end
            end
        end
    end
    
    return false
end

