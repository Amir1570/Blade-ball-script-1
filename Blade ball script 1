-- [2] دالة التحقق من المكان (هل أنا في المباراة؟)
local function IsInArena()
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    -- إذا كان ارتفاع اللاعب (Y) أقل من مستوى معين أو في منطقة اللوبي، سيتوقف
    -- في Blade Ball، ساحة القتال عادة تكون في إحداثيات معينة، أو بعيدة عن منطقة الرسباون
    -- سنستخدم التحقق من وجود "الكرة" كدليل قاطع داخل المباراة
    if workspace:FindFirstChild("Ball", true) or workspace:FindFirstChild("BaseBall", true) then
        return true
    end
    return false
end

