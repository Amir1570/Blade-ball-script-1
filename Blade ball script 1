local LP = Players.LocalPlayer
local FileName = "AL_AMIR_Omega_Settings.json"

-- [1] الإعدادات الافتراضية والحفظ
local CFG = { 
    AutoJump = false, AutoWalk = false, AntiLag = false, 
    WalkSpeed = 22, JumpInterval = 1.0 
}

local function Save() if writefile then writefile(FileName, HttpService:JSONEncode(CFG)) end end
local function Load() if isfile and isfile(FileName) then local d = HttpService:JSONDecode(readfile(FileName)) for k,v in pairs(d) do CFG[k]=v end end end
Load()

-- [2] منطق الأمان والتحقق (الآلية الصحيحة)
local function IsInMatch()
    -- التحقق من الموقع: إذا كان اللاعب في اللوبي (غالباً إحداثيات Y مرتفعة أو منطقة معينة)
    -- هذا الفلتر يضمن عدم التحرك إلا في الساحة
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local Balls = workspace:FindFirstChild("Balls")
    if not Balls or #Balls:GetChildren() == 0 then return false end
    
    for _, ball in ipairs(Balls:GetChildren()) do
        -- شرط الكرة المتحركة (سرعة > 10)
        if ball:IsA("BasePart") and ball.AssemblyLinearVelocity.Magnitude > 10 then
            return true
        end
    end
    return false
end

local lastJump, lastWalk = 0, 0
local Dirs = {Vector3.new(1,0,0), Vector3.new(-1,0,0), Vector3.new(0,0,1), Vector3.new(0,0,-1)}

RunService.Heartbeat:Connect(function()
    if not IsInMatch() then return end -- "يتوقف فوراً" حسب البروتوكول

    local char = LP.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end

    local now = tick()
    
    -- تطبيق سرعة الحركة المخصصة
    hum.WalkSpeed = CFG.WalkSpeed

    -- القفز الذكي
    if CFG.AutoJump and now - lastJump >= CFG.JumpInterval then
        lastJump = now
        hum.Jump = true
    end

    -- المشي التلقائي
    if CFG.AutoWalk and now - lastWalk >= 0.5 then
        lastWalk = now
        hum:MoveTo(hrp.Position + Dirs[math.random(1, #Dirs)] * 15)
    end
end)

