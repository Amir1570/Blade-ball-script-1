Toggle(P3, "⚡  Ultra Anti-Lag", "يحذف المؤثرات + عناصر الخريطة + رمادي", 3, function(on)
    CFG.AntiLag = on
    
    if on then
        if antiLagConnection then antiLagConnection:Disconnect() end
        
        -- 1. تحويل الشاشة للرمادي
        if ColorCorrection then ColorCorrection:Destroy() end
        ColorCorrection = Instance.new("ColorCorrectionEffect")
        ColorCorrection.Saturation = -1
        ColorCorrection.Parent = Lighting
        
        -- 2. إعدادات الإضاءة
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.FogStart = 9e9
        Lighting.Brightness = 2
        Lighting.ClockTime = 14
        
        -- 3. تنظيف العناصر الثقيلة (مرة واحدة)
        CleanHeavyElements()
        
        -- 4. حلقة خفيفة للحفاظ على النظافة (كل 5 ثواني)
        antiLagConnection = RunService.Stepped:Connect(function()
            if not CFG.AntiLag then return end
            pcall(function()
                for _, v in ipairs(Workspace:GetDescendants()) do
                    if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                        v.Enabled = false
                    end
                    if v:IsA("BasePart") then
                        v.CastShadow = false
                    end
                end
            end)
        end)
        
        SetStatus("Anti-Lag ⚡", C.Yellow)
        
    else
        if antiLagConnection then antiLagConnection:Disconnect() end
        antiLagConnection = nil
        
        if ColorCorrection then ColorCorrection:Destroy() end
        ColorCorrection = nil
        
        Lighting.GlobalShadows = true
        Lighting.FogEnd = 100000
        Lighting.FogStart = 0
        Lighting.Brightness = 1
        
        SetStatus("خامل", C.Muted)
    end
end)

