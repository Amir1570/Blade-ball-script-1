-- [2] منطق القفز والمشي الصلب (Hard-Coded) - يعمل في كل وقت
local CFG = { Walk = false, Jump = false, AntiLag = false }
local Dirs = { Vector3.new(1,0,0), Vector3.new(-1,0,0), Vector3.new(0,0,1), Vector3.new(0,0,-1) }
local lastWalk = 0

task.spawn(function()
    while task.wait() do
        local char = LP.Character
        local hum = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then continue end

        -- المشي العشوائي الخام
        if CFG.Walk and tick() - lastWalk > 0.4 then
            lastWalk = tick()
            hum:MoveTo(hrp.Position + Dirs[math.random(1, #Dirs)] * 15)
        end

        -- القفز الخام بالتوقيت المطلوب
        if CFG.Jump then
            if hum.FloorMaterial ~= Enum.Material.Air and hum.MoveDirection.Magnitude > 0 then
                hum.Jump = true -- القفزة الأولى
                task.wait(0.15) -- الانتظار الأول
                if hum then hum.Jump = true end -- القفزة الثانية
                task.wait(0.2) -- الانتظار قبل تكرار الدورة
            end
        end
    end
end)

