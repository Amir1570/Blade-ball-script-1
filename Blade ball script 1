-- AUTO PARRY
-- ══════════════════════════════════════════════
local lastParry = 0
local function TryParry()
    if tick() - lastParry < 0.18 then return end
    local char = LP.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local n = obj.Name:lower()
            if n:find("ball") or n:find("blade") or n:find("orb") or n:find("proj") then
                if (obj.Position - hrp.Position).Magnitude < 30 then
                    lastParry = tick()
                    task.delay(CFG.ParryDelay, function()
                        for _, rn in ipairs({"Parry","ParryEvent","parry","RE",
                            "Remote","Block","BlockEvent","Deflect","parryEvent"}) do
                            local r = RS:FindFirstChild(rn, true)
                            if r and r:IsA("RemoteEvent") then
                                pcall(function() r:FireServer() end)
                                SetStatus("تم الصد! 🛡", C.Green)
                                Log("صد ناجح 🛡", C.Green)
                                return
                            end
                        end
                    end)
                    break
                end
            end
        end
    end
end

