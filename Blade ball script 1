-- توليد متجهات عشوائية مستمرة لتغذية المحرك
task.spawn(function()
    while task.wait(0.6) do
        if CFG.Walk then
            MoveDir = Vector3.new(math.random(-10, 10), 0, math.random(-10, 10)).Unit
        else
            MoveDir = Vector3.new(0, 0, 0)
        end
    end
end)

-- حقن الحركة المستمرة (يتجاوز حماية MoveTo)
RunService.RenderStepped:Connect(function()
    local char = LP.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum and CFG.Walk then
        hum:Move(MoveDir, true)
    end
end)

-- مراقبة حالة الهبوط لإعادة ضبط القفز
RunService.Heartbeat:Connect(function()
    local char = LP.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum and (hum:GetState() == Enum.HumanoidStateType.Landed or hum.FloorMaterial ~= Enum.Material.Air) then
        JumpCount = 0
    end
end)

-- حقن القفز المزدوج باستخدام طلبات نظام اللعبة الأساسي
UserInputService.JumpRequest:Connect(function()
    if CFG.Jump then
        local char = LP.Character
        local hum = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        
        if hum and hrp and JumpCount < 1 then
            JumpCount = JumpCount + 1
            
            -- توليد كائن دفع فيزيائي يتجاهل الجاذبية وتعديلات السكربتات الأخرى
            local BV = Instance.new("BodyVelocity")
            BV.Velocity = Vector3.new(hrp.Velocity.X, 55, hrp.Velocity.Z)
            BV.MaxForce = Vector3.new(0, 100000, 0)
            BV.Parent = hrp
            
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            
            -- إزالة الدفع الفيزيائي بعد إتمام القفزة
            game:GetService("Debris"):AddItem(BV, 0.15)
        end
    end
end)
