local fT, fS = 0, {}
RunService.Heartbeat:Connect(function(dt)
    table.insert(fS, 1/math.max(dt,0.001))
    if #fS > 30 then table.remove(fS,1) end
    fT += dt
    if fT >= 0.5 then
        fT = 0
        local s = 0
        for _, v in ipairs(fS) do s += v end
        local avg = math.floor(s/#fS)
        local col = avg >= 50 and C.Green or avg >= 25 and C.Yellow or C.Red
        local txt = "⚡ FPS: "..avg
        fLbl.Text = txt;  fLbl.TextColor3  = col
        pfLbl.Text = txt; pfLbl.TextColor3 = col
    end
end)

