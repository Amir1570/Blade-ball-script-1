        Lighting.GlobalShadows = not on
        Lighting.FogEnd        = on and 9e8 or 100000
        Lighting.FogStart      = on and 9e8 or 0
        Lighting.Brightness    = on and 2 or 1
        for _, v in ipairs(workspace:GetDescendants()) do
            pcall(function()
                if v:IsA("ParticleEmitter") or v:IsA("Trail")
                or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
                    v.Enabled = not on
                end
                if v:IsA("PostEffect") or v:IsA("BlurEffect")
                or v:IsA("ColorCorrectionEffect") or v:IsA("SunRaysEffect")
                or v:IsA("BloomEffect") or v:IsA("DepthOfFieldEffect") then
                    v.Enabled = not on
                end
                if v:IsA("Decal") or v:IsA("Texture") then
                    v.Transparency = on and 1 or 0
                end
            end)
        end
    end)
    SetStatus(on and "Anti-Lag ⚡" or "خامل", on and C.Yellow or nil)
end)

