-- ====================== Smart Auto Parry (Polaris Pro) ======================
local ParryConnection
local function StartSmartAutoParry()
    if ParryConnection then return end
    ParryConnection = RunService.Heartbeat:Connect(function()
        if not Settings.AutoParry or not InMatch then return end
        local ball = Workspace:FindFirstChild("Ball") or Workspace:FindFirstChild("TheBall")
        if not ball or not RootPart then return end

        local dist = (ball.Position - RootPart.Position).Magnitude
        local vel = ball.Velocity
        local relativeVel = vel - RootPart.Velocity
        local eta = (relativeVel.Magnitude > 5) and (dist / relativeVel.Magnitude) or 999

        local directionToPlayer = (RootPart.Position - ball.Position).Unit
        local isComingTowards = vel:Dot(directionToPlayer) > 0

        if dist < 40 and isComingTowards and eta < 0.65 then
            local rem = ReplicatedStorage:FindFirstChild("Remotes")
            if rem and rem:FindFirstChild("ParryButtonPress") then
                rem.ParryButtonPress:Fire()
            end
        end
    end)
end
local function StopSmartAutoParry()
    if ParryConnection then ParryConnection:Disconnect() ParryConnection = nil end
end

