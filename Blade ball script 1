-- ══════════════════════════════════════════════
RunService.Heartbeat:Connect(function()
    pcall(function()
        local char = LP.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        local now = tick()
        
        -- التحقق من أننا في مباراة حقيقية
        local inRealGame = workspace:FindFirstChild("GameTimer") ~= nil
        
        -- ══════════════════════════════════════
        -- AUTO PARRY (محسن: يستخدم الدالة الجديدة)
        -- ══════════════════════════════════════
        if CFG.AutoParry and ParryRE and now - lastParryTime >= PARRY_COOLDOWN then
            if IsBallTargetingMe() then
                lastParryTime = now
                pcall(function() ParryRE:Fire() end)
                SetStatus("تم الصد! 🛡", C.Green)
                Log("صد ✅", C.Green)
            end
        end
        
        -- ══════════════════════════════════════
        -- AUTO ABILITY (محسن: يستخدم الدالة الجديدة)
        -- ══════════════════════════════════════
        if CFG.AutoAbility and AbilityRE and now - lastAbilityTime >= ABILITY_COOLDOWN then
            if IsBallTargetingMe() then
                lastAbilityTime = now
                pcall(function() AbilityRE:Fire() end)
                Log("قدرة ✨", C.Yellow)
            end
        end
        
        -- ══════════════════════════════════════
        -- AUTO JUMP (تم الإصلاح)
        -- ══════════════════════════════════════
        if CFG.AutoJump and now - lastJump >= CFG.JumpInterval then
            lastJump = now
            -- التحقق من أن اللاعب على الأرض
            if hum:GetState() == Enum.HumanoidStateType.Landed or hum:GetState() == Enum.HumanoidStateType.Running then
                hum.Jump = true
            end
        end
        
        -- ══════════════════════════════════════
        -- AUTO WALK (فقط في المباراة الحقيقية)
        -- ══════════════════════════════════════
        if CFG.AutoWalk and inRealGame and now - lastWalk >= 0.6 then
            lastWalk = now
            hum:MoveTo(hrp.Position + Dirs[math.random(1,#Dirs)] * 22)
        end
        
        -- ══════════════════════════════════════
        -- RANDOM MOVE (فقط في المباراة الحقيقية)
        -- ══════════════════════════════════════
        if CFG.RandomMove and inRealGame and now - lastRandom >= CFG.MoveInterval then
            lastRandom = now
            hum:MoveTo(hrp.Position + Dirs[math.random(1,#Dirs)] * 16)
        end
    end)
end)

