-- Tabs
local TabBar = Instance.new("Frame", Main)
TabBar.Size = UDim2.new(1, -20, 0, 35); TabBar.Position = UDim2.new(0, 10, 0, 40); TabBar.BackgroundTransparency = 1
Instance.new("UIListLayout", TabBar).FillDirection = Enum.FillDirection.Horizontal

local Content = Instance.new("Frame", Main)
Content.Size = UDim2.new(1, -20, 1, -90); Content.Position = UDim2.new(0, 10, 0, 80); Content.BackgroundTransparency = 1

local TPages = {}
local function CreateTab(name, icon, active)
    local b = Instance.new("TextButton", TabBar); b.Size = UDim2.new(0.33, -2, 1, 0); b.Text = icon
    b.BackgroundColor3 = active and Color3.fromRGB(99, 102, 241) or Color3.fromRGB(25, 25, 35); b.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", b)

    local p = Instance.new("ScrollingFrame", Content); p.Size = UDim2.new(1, 0, 1, 0); p.Visible = active; p.BackgroundTransparency = 1
    p.AutomaticCanvasSize = Enum.AutomaticSize.Y; Instance.new("UIListLayout", p).Padding = UDim.new(0, 8)

    b.MouseButton1Click:Connect(function()
        for k, v in pairs(TPages) do v.Visible = (k == name) end
        for _, btn in pairs(TabBar:GetChildren()) do if btn:IsA("TextButton") then btn.BackgroundColor3 = Color3.fromRGB(25, 25, 35) end end
        b.BackgroundColor3 = Color3.fromRGB(99, 102, 241)
    end)
    TPages[name] = p; return p
end

