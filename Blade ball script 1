local function IsMovingBallExists()
    if not Balls then return false end
    for _, ball in ipairs(Balls:GetChildren()) do
        if ball:IsA("BasePart") and ball.AssemblyLinearVelocity.Magnitude > 10 then
            return true
        end
    end
    return false
end

-- ══ PATHFINDING ══
local aiWalking = false
local aiThread  = nil

local function StopAIWalk()
    aiWalking = false
    if aiThread then pcall(function() task.cancel(aiThread) end); aiThread = nil end
end

local function GetSafeTarget(hrp)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    local char = LP.Character
    if char then params.FilterDescendantsInstances = {char} end
    for _ = 1, 8 do
        local a = math.random() * math.pi * 2
        local d = math.random(8, 18)
        local t = hrp.Position + Vector3.new(math.cos(a)*d, 0, math.sin(a)*d)
        local ray = workspace:Raycast(t + Vector3.new(0,5,0), Vector3.new(0,-15,0), params)
        if ray then return Vector3.new(t.X, ray.Position.Y+3, t.Z) end
    end
    return nil
end

local function StartAIWalk()
    if aiWalking then return end
    aiWalking = true
    aiThread = task.spawn(function()
        while aiWalking do
            pcall(function()
                if not IsMovingBallExists() then task.wait(0.5); return end
                local char = LP.Character; if not char then task.wait(0.5); return end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")
                if not hrp or not hum or hum.Health <= 0 then task.wait(0.5); return end
                local target = GetSafeTarget(hrp)
                if not target then task.wait(0.3); return end
                local path = PathfindingService:CreatePath({AgentRadius=2,AgentHeight=5,AgentCanJump=true,WaypointSpacing=4})
                local ok = pcall(function() path:ComputeAsync(hrp.Position, target) end)
                if not ok or path.Status ~= Enum.PathStatus.Success then
                    hum:MoveTo(target); task.wait(0.8); return
                end
                for _, wp in ipairs(path:GetWaypoints()) do
                    if not aiWalking or not IsMovingBallExists() then break end
                    local c = LP.Character; if not c then break end
                    local h = c:FindFirstChild("HumanoidRootPart")
                    local hu = c:FindFirstChild("Humanoid")
                    if not h or not hu or hu.Health <= 0 then break end
                    if wp.Action == Enum.PathWaypointAction.Jump then hu.Jump = true end
                    hu:MoveTo(wp.Position); hu.MoveToFinished:Wait(2)
                end
            end)
            task.wait(0.1)
        end
    end)
end

-- ══ ANTI LAG ══
local function ApplyAntiLag()
    pcall(function()
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Trail")
            or v:IsA("Smoke") or v:IsA("Fire") then v.Enabled = false end
            if v:IsA("BloomEffect") or v:IsA("BlurEffect")
            or v:IsA("SunRaysEffect") then v.Enabled = false end
            if v:IsA("BasePart") then v.CastShadow = false end
        end
    end)
end

-- ══ MAIN LOOP ══
local Dirs = {
    Vector3.new(1,0,0), Vector3.new(-1,0,0),
    Vector3.new(0,0,1), Vector3.new(0,0,-1),
    Vector3.new(1,0,1).Unit, Vector3.new(-1,0,-1).Unit,
    Vector3.new(1,0,-1).Unit, Vector3.new(-1,0,1).Unit,
}

RunService.Heartbeat:Connect(function()
    pcall(function()
        local char = LP.Character; if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        local now = tick()
        local ball = IsMovingBallExists()

        if CFG.AutoJump and ball and now - lastJump >= CFG.JumpInterval then
            lastJump = now; hum.Jump = true
            task.delay(0.15, function()
                pcall(function() if hum and hum.Parent then hum.Jump = true end end)
            end)
        end

        if CFG.AutoWalk then
            if ball and hum.Health > 0 then
                if not aiWalking then StartAIWalk() end
            else StopAIWalk() end
        else StopAIWalk() end

        if CFG.RandomMove and ball and now - lastRandom >= CFG.MoveInterval then
            lastRandom = now
            hum:MoveTo(hrp.Position + Dirs[math.random(1,#Dirs)] * 16)
        end
    end)
end)

