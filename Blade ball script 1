-- [[ FLATTING ICON & UI TOGGLE SYSTEM ]] --
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

-- التأكد من وجود الواجهة الرئيسية (الافتراض أنها مسماة MainFrame في السكربت السابق)
-- local MainFrame = ... (يتم دمج هذا الكود مع السكربت الكامل)

-- [1] إنشاء ScreenGui مستقل للزر العائم
local IconGui = Instance.new("ScreenGui", CoreGui)
IconGui.Name = "FloatingIconEngine"

-- [2] إنشاء الزر العائم (Mobile Optimized)
local FloatingBtn = Instance.new("TextButton", IconGui)
FloatingBtn.Size = UDim2.new(0, 50, 0, 50) -- حجم مناسب للمس
FloatingBtn.Position = UDim2.new(0.1, 0, 0.5, -25) -- الموقع الافتراضي
FloatingBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
FloatingBtn.Text = "B" -- اختصار Blade Ball
FloatingBtn.TextColor3 = Color3.new(1, 1, 1)
FloatingBtn.TextSize = 20
FloatingBtn.Active = true

-- إضافة حواف دائرية للجمالية
local UICorner = Instance.new("UICorner", FloatingBtn)
UICorner.CornerRadius = UDim.new(0.5, 0) -- دائرة كاملة

-- [3] منطق السحب (Dragging Logic for Mobile)
local dragging
local dragInput
local dragStart
local startPos

local function update(input)
    local delta = input.Position - dragStart
    FloatingBtn.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

FloatingBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = FloatingBtn.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

FloatingBtn.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- [4] منطق التبديل (Toggle GUI Visibility)
FloatingBtn.MouseButton1Click:Connect(function()
    if MainFrame then
        MainFrame.Visible = not MainFrame.Visible
    end
end)
