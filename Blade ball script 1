// Fix walk after death using Y position check
function checkWalkAfterDeath(player) {
    if (player.y < 0) { // Adjust condition based on your game logic
        player.canWalk = false;
    } else {
        player.canWalk = true;
    }
}

// Improve double jump with 0.2s delay
let canDoubleJump = true;
let jumpDelay = 200; // milliseconds

function doubleJump(player) {
    if (player.isJumping && canDoubleJump) {
        setTimeout(() => {
            player.jump();
            canDoubleJump = false; // Prevent further jumps until reset
        }, jumpDelay);
    }
}

// Add inGame check to all movement functions
function movePlayer(player, direction) {
    if (player.inGame) {
        // Movement logic here
        player.x += direction;
    }
}

function jumpPlayer(player) {
    if (player.inGame) {
        player.jump();
    }
}

// Reset double jump when the player lands
function resetDoubleJump(player) {
    if (player.isGrounded) {
        canDoubleJump = true;
    }
}