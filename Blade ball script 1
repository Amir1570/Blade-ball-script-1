local jumpCount = 0

RunService.Heartbeat:Connect(function()
    pcall(function()
        local char = LP.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        local now = tick()

        local inGame = IsInRealGame()

        -- تحديث مؤشر المكان
        gLbl.Text = inGame and "⚔ المكان: ساحة" or "🏠 المكان: لوبي"
        gLbl.TextColor3 = inGame and C.Green or C.Muted

        -- الإصلاح 2: القفز بدون شرط Landed
        if CFG.AutoJump and now - lastJump >= CFG.JumpInterval then
            lastJump = now
            -- القفزة الأولى
            hum.Jump = true
            -- القفزة الثانية بعد 0.15 ثانية
            task.delay(0.15, function()
                pcall(function()
                    if hum and hum.Parent then
                        hum.Jump = true
                        hum:ChangeState(Enum.HumanoidStateType.Jumping)
                    end
                end)
            end)
        end

        -- المشي فقط في المباراة
        if CFG.AutoWalk and inGame and now - lastWalk >= 0.6 then
            lastWalk = now
            hum:MoveTo(hrp.Position + Dirs[math.random(1,#Dirs)] * 22)
        end

        -- الحركة العشوائية فقط في المباراة
        if CFG.RandomMove and inGame and now - lastRandom >= CFG.MoveInterval then
            lastRandom = now
            hum:MoveTo(hrp.Position + Dirs[math.random(1,#Dirs)] * 16)
        end
    end)
end)

