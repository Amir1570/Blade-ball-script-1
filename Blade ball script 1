local RootPart = Character:WaitForChild("HumanoidRootPart")

-- ====================== إعدادات ======================
local SettingsFile = "BladeBall_Raw_v7_1.json"
local Settings = {
    AutoWalk = true,
    DoubleJump = true,
    UltraAntiLag = true,
    AutoParry = true,
    AutoAbility = true,
    RadialField = true,
}

local function LoadSettings()
    if isfile and isfile(SettingsFile) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(SettingsFile)) end)
        if success then Settings = data end
    end
end

local function SaveSettings()
    if writefile then
        pcall(function() writefile(SettingsFile, HttpService:JSONEncode(Settings)) end)
    end
end

LoadSettings()

-- ====================== Levi Walk + Match Detection ======================
local InMatch = false
local RandomWalkThread = nil

local function IsInMatch()
    return Workspace:FindFirstChild("Ball") or Workspace:FindFirstChild("TheBall")
end

local function StartRandomWalk()
    if RandomWalkThread then return end
    RandomWalkThread = task.spawn(function()
        while Settings.AutoWalk and InMatch and Character and Humanoid.Health > 0 do
            local rx = math.random(-70, 70)
            local rz = math.random(-70, 70)
            local target = RootPart.Position + Vector3.new(rx, 5, rz)
            local path = PathfindingService:CreatePath({AgentRadius = 3, AgentHeight = 6, AgentCanJump = true})
            path:ComputeAsync(RootPart.Position, target)
            if path.Status == Enum.PathStatus.Success then
                for _, wp in ipairs(path:GetWaypoints()) do
                    if not (Settings.AutoWalk and InMatch) then break end
                    Humanoid:MoveTo(wp.Position)
                    Humanoid.MoveToFinished:Wait(2)
                    if math.random(1,4) == 1 then
                        Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                        task.wait(0.3)
                    end
                end
            else
                Humanoid:MoveTo(target)
                task.wait(math.random(2,4))
            end
            task.wait(math.random(1.5, 3.5))
        end
    end)
end

local function StopRandomWalk()
    if RandomWalkThread then task.cancel(RandomWalkThread) RandomWalkThread = nil end
    if Humanoid then Humanoid:MoveTo(RootPart.Position) end
end

-- مراقبة المباراة
Workspace.ChildAdded:Connect(function(child)
    if child.Name == "Ball" or child.Name == "TheBall" then
        InMatch = true
        if Settings.AutoWalk then StartRandomWalk() end
    end
end)

Workspace.ChildRemoved:Connect(function(child)
    if child.Name == "Ball" or child.Name == "TheBall" then
        InMatch = false
        StopRandomWalk()
    end
end)

-- ====================== Radial Field ======================
local RadialGui = Instance.new("ScreenGui")
RadialGui.ResetOnSpawn = false
RadialGui.Parent = LocalPlayer.PlayerGui

local RadialFrame = Instance.new("Frame")
RadialFrame.Size = UDim2.new(0, 420, 0, 420)
RadialFrame.Position = UDim2.new(0.5, -210, 0.5, -210)
RadialFrame.BackgroundTransparency = 1
RadialFrame.Parent = RadialGui

Instance.new("UICorner", RadialFrame).CornerRadius = UDim.new(0.5, 0)

local RadialStroke = Instance.new("UIStroke")
RadialStroke.Thickness = 14
RadialStroke.Transparency = 0.35
RadialStroke.Parent = RadialFrame

local function UpdateRadialField()
    if not Settings.RadialField then
        RadialStroke.Color = Color3.fromRGB(80, 80, 80)
        return
    end
    local ball = Workspace:FindFirstChild("Ball") or Workspace:FindFirstChild("TheBall")
    if not ball or not RootPart then 
        RadialStroke.Color = Color3.fromRGB(100, 100, 100)
        RadialFrame.Size = UDim2.new(0, 380, 0, 380)
        return 
    end

    local dist = (ball.Position - RootPart.Position).Magnitude
    local speed = ball.Velocity.Magnitude

    if dist < 25 and speed > 18 then
        RadialStroke.Color = Color3.fromRGB(0, 255, 80)   -- Green
        RadialFrame.Size = UDim2.new(0, 460, 0, 460)
    elseif dist < 35 then
        RadialStroke.Color = Color3.fromRGB(255, 200, 0)  -- Yellow
        RadialFrame.Size = UDim2.new(0, 410, 0, 410)
    else
        RadialStroke.Color = Color3.fromRGB(255, 50, 50)  -- Red
        RadialFrame.Size = UDim2.new(0, 380, 0, 380)
    end
end

RunService.RenderStepped:Connect(UpdateRadialField)

-- ====================== Auto Parry ======================
local ParryRemote = nil
local AbilityRemote = nil
local parryRunning = false
local parryThread = nil

local function FindParryRemotes()
    pcall(function()
        local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
        if Remotes then
            ParryRemote   = Remotes:FindFirstChild("ParryButtonPress")
                         or Remotes:FindFirstChild("Parry")
            AbilityRemote = Remotes:FindFirstChild("AbilityButtonPress")
                         or Remotes:FindFirstChild("Ability")
        end
    end)
end
FindParryRemotes()

local function StartSmartAutoParry()
    if parryRunning then return end
    parryRunning = true
    parryThread = task.spawn(function()
        while parryRunning do
            pcall(function()
                if not Settings.AutoParry then return end
                local char = LocalPlayer.Character
                if not char then return end
                -- الصد عند وجود Highlight (الكرة تستهدفك)
                if char:FindFirstChild("Highlight") then
                    if ParryRemote then
                        pcall(function() ParryRemote:FireServer() end)
                    end
                    -- القدرة التلقائية
                    if Settings.AutoAbility and AbilityRemote then
                        pcall(function() AbilityRemote:FireServer() end)
                    end
                end
            end)
            task.wait(0.15)
        end
    end)
end

local function StopSmartAutoParry()
    parryRunning = false
    if parryThread then
        pcall(function() task.cancel(parryThread) end)
        parryThread = nil
    end
end

-- ====================== Ultra Anti-Lag ======================
local function ActivateUltraAntiLag()
    pcall(function()
        Lighting.GlobalShadows = false
        Lighting.FogEnd        = 9e9
        Lighting.FogStart      = 9e9
        Lighting.Brightness    = 2

        -- رمادي
        if not Lighting:FindFirstChild("BB_CC") then
            local cc = Instance.new("ColorCorrectionEffect")
            cc.Name = "BB_CC"
            cc.Saturation = -1
            cc.Parent = Lighting
        end

        for _, v in ipairs(workspace:GetDescendants()) do
            pcall(function()
                if v:IsA("ParticleEmitter") or v:IsA("Trail")
                or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
                    v.Enabled = false
                end
                if v:IsA("BloomEffect") or v:IsA("BlurEffect")
                or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") then
                    v.Enabled = false
                end
                if v:IsA("BasePart") then
                    v.CastShadow = false
                end
            end)
        end
    end)
end

