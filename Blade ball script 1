-- ====================== دالة Toggle ======================
local lastTap = 0
local function CreateToggle(text, key, order)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 58)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    frame.LayoutOrder = order
    frame.Parent = ContentFrame
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.65, 0, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.TextSize = 21
    label.Font = Enum.Font.GothamSemibold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame

    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(0.3, 0, 1, 0)
    status.Position = UDim2.new(0.68, 0, 0, 0)
    status.BackgroundTransparency = 1
    status.Text = Settings[key] and "ON" or "OFF"
    status.TextColor3 = Settings[key] and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(180, 180, 180)
    status.TextSize = 21
    status.Font = Enum.Font.GothamBold
    status.Parent = frame

    -- ✅ الإصلاح: InputBegan + InputEnded للكشف الصحيح عن الضغط
    local touchStart = nil
    frame.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            touchStart = inp.Position
        end
    end)
    frame.InputEnded:Connect(function(inp)
        if (inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseButton1) and touchStart then
            local delta = (inp.Position - touchStart).Magnitude
            if delta > 20 then touchStart = nil; return end
            if tick() - lastTap < 0.3 then touchStart = nil; return end
            lastTap = tick()
            touchStart = nil

            Settings[key] = not Settings[key]
            status.Text = Settings[key] and "ON" or "OFF"
            status.TextColor3 = Settings[key] and Color3.fromRGB(0,255,100) or Color3.fromRGB(180,180,180)
            SaveSettings()

            if key == "AutoWalk" then
                if Settings.AutoWalk and InMatch then StartRandomWalk() else StopRandomWalk() end
            elseif key == "UltraAntiLag" then
                if Settings.UltraAntiLag then ActivateUltraAntiLag() end
            elseif key == "AutoParry" then
                if Settings.AutoParry then StartSmartAutoParry() else StopSmartAutoParry() end
            end
        end
    end)
end

