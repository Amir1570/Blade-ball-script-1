    end
end)

-- [2] منطق الحركة الأصلي (الذي يعمل لديك)
local Balls = workspace:WaitForChild("Balls", 15)
local CFG = { AutoJump = false, AutoWalk = false, AntiLag = false }
local lastJump, lastWalk = 0, 0
local Dirs = { Vector3.new(1, 0, 0), Vector3.new(-1, 0, 0), Vector3.new(0, 0, 1), Vector3.new(0, 0, -1) }

local function IsMovingBallExists()
    if not Balls then return false end
    for _, ball in ipairs(Balls:GetChildren()) do
        if ball:IsA("BasePart") and ball.AssemblyLinearVelocity.Magnitude > 10 then
            return true
        end
    end
    return false
end

-- [3] محرك التشغيل (Loop)
RunService.Heartbeat:Connect(function()
    local char = LP.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end

    local now = tick()
    local isActive = IsMovingBallExists()

    -- القفز التلقائي (المنطق الأصلي)
    if CFG.AutoJump and isActive and now - lastJump >= 1.0 then
        lastJump = now
        hum.Jump = true
        task.delay(0.15, function() if hum then hum.Jump = true end end)
    end

    -- المشي التلقائي (المنطق الأصلي)
    if CFG.AutoWalk and isActive and now - lastWalk >= 0.6 then
        lastWalk = now
        hum:MoveTo(hrp.Position + Dirs[math.random(1, #Dirs)] * 22)
    end
end)

