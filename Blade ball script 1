-- ==============================================
-- الدالة الأساسية: تحديد حالة اللاعب (من الهيكل الذي استنتجناه)
-- ==============================================
-- حالات اللاعب:
-- "Lobby"           - في اللوبي (تحت الخريطة، Y < -50)
-- "Spectating"      - ميت/مشاهدة (Health <= 0 أو وجود GameTimer بدون Highlight)
-- "InGame_Targeted" - في المباراة والكرة تستهدفك (Highlight موجود)
-- "InGame_NotTargeted" - في المباراة والكرة لا تستهدفك (كرة متحركة فقط)
-- ==============================================
local function GetPlayerState()
    local char = LP.Character
    if not char then return "Lobby" end
    
    local hum = char:FindFirstChild("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    
    -- 1. ميت أو مشاهدة
    if not hum or hum.Health <= 0 then
        return "Spectating"
    end
    
    -- 2. اللوبي: تحت الخريطة (Y < -50)
    if hrp and hrp.Position.Y < -50 then
        return "Lobby"
    end
    
    -- 3. وجود كرة متحركة في الساحة (دليل على وجود مباراة)
    local hasMovingBall = false
    if Balls then
        for _, ball in ipairs(Balls:GetChildren()) do
            if ball:IsA("BasePart") then
                local vel = ball.AssemblyLinearVelocity
                if vel.Magnitude > 10 then
                    hasMovingBall = true
                    break
                end
            end
        end
    end
    
    if not hasMovingBall then
        return "Lobby"
    end
    
    -- 4. التحقق من الاستهداف (Highlight)
    local isTargeted = char:FindFirstChild("Highlight") ~= nil
    
    if isTargeted then
        return "InGame_Targeted"
    else
        return "InGame_NotTargeted"
    end
end

-- هل اللاعب في المباراة (للحركة)
local function IsInMatch()
    local state = GetPlayerState()
    return state == "InGame_Targeted" or state == "InGame_NotTargeted"
end

-- هل اللاعب حي؟
local function IsAlive()
    local char = LP.Character
    if not char then return false end
    local hum = char:FindFirstChild("Humanoid")
    return hum and hum.Health > 0
end

