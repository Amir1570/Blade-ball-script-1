-- ====================== Radial Field (الحقل الشعاعي) ======================
local RadialGui = Instance.new("ScreenGui")
RadialGui.ResetOnSpawn = false
RadialGui.Parent = LocalPlayer.PlayerGui

local RadialFrame = Instance.new("Frame")
RadialFrame.Size = UDim2.new(0, 420, 0, 420)
RadialFrame.Position = UDim2.new(0.5, -210, 0.5, -210)
RadialFrame.BackgroundTransparency = 1
RadialFrame.Parent = RadialGui

local RadialCorner = Instance.new("UICorner")
RadialCorner.CornerRadius = UDim.new(0.5, 0)
RadialCorner.Parent = RadialFrame

local RadialStroke = Instance.new("UIStroke")
RadialStroke.Thickness = 12
RadialStroke.Color = Color3.fromRGB(0, 255, 100)
RadialStroke.Transparency = 0.4
RadialStroke.Parent = RadialFrame

local function UpdateRadial()
    local ball = Workspace:FindFirstChild("Ball") or Workspace:FindFirstChild("TheBall")
    if not ball or not RootPart or not Settings.RadialField then
        RadialStroke.Color = Color3.fromRGB(100, 100, 100)
        RadialFrame.Size = UDim2.new(0, 380, 0, 380)
        return
    end

    local dist = (ball.Position - RootPart.Position).Magnitude
    local vel = ball.Velocity.Magnitude

    if dist < 22 and vel > 20 then
        RadialStroke.Color = Color3.fromRGB(0, 255, 100)   -- Green
        RadialFrame.Size = UDim2.new(0, 460, 0, 460)
    elseif dist < 32 then
        RadialStroke.Color = Color3.fromRGB(255, 220, 0)   -- Yellow
        RadialFrame.Size = UDim2.new(0, 410, 0, 410)
    else
        RadialStroke.Color = Color3.fromRGB(255, 60, 60)   -- Red
        RadialFrame.Size = UDim2.new(0, 380, 0, 380)
    end
end

RunService.RenderStepped:Connect(UpdateRadial)

