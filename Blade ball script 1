-- [5] محرك الحركة (المشي فقط في المباراة)
local MoveDir = Vector3.new(1, 0, 1)
task.spawn(function()
    while task.wait(0.5) do
        MoveDir = Vector3.new(math.random(-1, 1), 0, math.random(-1, 1))
    end
end)

RunService.RenderStepped:Connect(function()
    if CFG.Walk and IsInArena() then
        local char = LP.Character
        local hum = char and char:FindFirstChild("Humanoid")
        if hum then
            hum:Move(MoveDir, true)
        end
    end
end)

-- [6] محرك القفز (تصحيح نهائي)
UserInputService.JumpRequest:Connect(function()
    if CFG.Jump then
        local char = LP.Character
        local hum = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        
        if hum and hrp then
            if hum:GetState() == Enum.HumanoidStateType.Jumping or hum:GetState() == Enum.HumanoidStateType.Freefall then
                if JumpCount < 1 then
                    JumpCount = 1
                    -- دفع فيزيائي للأعلى يتخطى حماية اللعبة
                    hrp.Velocity = Vector3.new(hrp.Velocity.X, 60, hrp.Velocity.Z)
                end
            end
        end
    end
end)

RunService.Heartbeat:Connect(function()
    local char = LP.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum and (hum.FloorMaterial ~= Enum.Material.Air) then
        JumpCount = 0
    end
end)
