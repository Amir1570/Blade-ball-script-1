local Player = game:GetService("Players").LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

-- حذف أي نسخ قديمة لتجنب التداخل
if PlayerGui:FindFirstChild("AL_AMIR_ENGINE") then
    PlayerGui.AL_AMIR_ENGINE:Destroy()
end

-- [1] الحاوية الأساسية (Top-Level Container)
local ScreenGui = Instance.new("ScreenGui", PlayerGui)
ScreenGui.Name = "AL_AMIR_ENGINE"
ScreenGui.ResetOnSpawn = false
ScreenGui.DisplayOrder = 999 -- ضمان الظهور فوق كل شيء

-- [2] الزر العائم (The B Button)
local FloatingBtn = Instance.new("TextButton", ScreenGui)
FloatingBtn.Name = "MainTrigger"
FloatingBtn.Size = UDim2.new(0, 50, 0, 50)
FloatingBtn.Position = UDim2.new(0.1, 0, 0.4, 0)
FloatingBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 120)
FloatingBtn.Text = "B"
FloatingBtn.TextColor3 = Color3.new(0,0,0)
FloatingBtn.TextSize = 25
FloatingBtn.Active = true
FloatingBtn.Draggable = true -- سحب الزر

local UICorner = Instance.new("UICorner", FloatingBtn)
UICorner.CornerRadius = UDim.new(1, 0)

-- [3] الإطار الرئيسي (The Real Menu)
local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Name = "ControlPanel"
MainFrame.Size = UDim2.new(0, 200, 0, 250)
MainFrame.Position = UDim2.new(0.5, -100, 0.5, -125)
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.BorderSizePixel = 2
MainFrame.BorderColor3 = Color3.fromRGB(0, 255, 120)
MainFrame.Visible = false -- يبدأ مخفياً

-- [4] المتغيرات التقنية
local Config = { Walking = false, Jump = true }
local JumpCount = 0

-- [5] إضافة الأزرار داخل الإطار (Internal UI Elements)
local function AddButton(txt, yPos, callback)
    local b = Instance.new("TextButton", MainFrame)
    b.Size = UDim2.new(0.9, 0, 0, 45)
    b.Position = UDim2.new(0.05, 0, 0, yPos)
    b.Text = txt
    b.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.Gotham
    b.MouseButton1Click:Connect(function() callback(b) end)
end

AddButton("Auto Walk: OFF", 20, function(self)
    Config.Walking = not Config.Walking
    self.Text = "Auto Walk: " .. (Config.Walking and "ON" or "OFF")
    self.BackgroundColor3 = Config.Walking and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(50, 50, 50)
end)

AddButton("Double Jump: ON", 80, function(self)
    Config.Jump = not Config.Jump
    self.Text = "Double Jump: " .. (Config.Jump and "ON" or "OFF")
end)

AddButton("Anti-Lag Magic", 140, function(self)
    self.Text = "Optimizing..."
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("ParticleEmitter") or v:IsA("Trail") then v.Enabled = false end
    end
    wait(1)
    self.Text = "Lag Fixed!"
end)

AddButton("CLOSE SCRIPT", 200, function()
    ScreenGui:Destroy()
end)

-- [6] منطق التبديل (Toggle UI)
FloatingBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = not MainFrame.Visible
end)

-- [7] المحرك التنفيذي (Core Logic)
RunService.Heartbeat:Connect(function()
    local Char = Player.Character
    local Hum = Char and Char:FindFirstChild("Humanoid")
    
    -- المشي العشوائي
    if Config.Walking and Hum and Hum.Health > 0 then
        if Hum.MoveDirection.Magnitude == 0 then
            local Target = Char.PrimaryPart.Position + Vector3.new(math.random(-25, 25), 0, math.random(-25, 25))
            Hum:MoveTo(Target)
        end
    end
    
    -- تصفير القفز
    if Hum and Hum:GetState() == Enum.HumanoidStateType.Landed then
        JumpCount = 0
    end
end)

UserInputService.JumpRequest:Connect(function()
    if Config.Jump then
        local Hum = Player.Character and Player.Character:FindFirstChild("Humanoid")
        if Hum and JumpCount < 2 then
            Hum:ChangeState(Enum.HumanoidStateType.Jumping)
            JumpCount = JumpCount + 1
        end
    end
end)
