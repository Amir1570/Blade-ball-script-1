-- [[ AL-AMIR V12.0 - NON-STOP JUMP & RANDOM MOVE ]] --
local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- تنظيف الواجهات القديمة
pcall(function()
    for _, v in pairs(LP.PlayerGui:GetChildren()) do
        if v.Name:find("BB_") or v.Name:find("AL_AMIR") then v:Destroy() end
    end
end)

local CFG = { Active = false }
local Balls = workspace:WaitForChild("Balls", 10)
local Dirs = {Vector3.new(1,0,0), Vector3.new(-1,0,0), Vector3.new(0,0,1), Vector3.new(0,0,-1)}
local lastWalk = 0

-- وظيفة فحص وجود مباراة (كرة متحركة) لضمان التوقف في اللوبي
local function IsInMatch()
    if not Balls then return false end
    for _, ball in ipairs(Balls:GetChildren()) do
        if ball:IsA("BasePart") and ball.AssemblyLinearVelocity.Magnitude > 10 then
            return true
        end
    end
    return false
end

RunService.Heartbeat:Connect(function()
    if not CFG.Active then return end
    
    local char = LP.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end

    if IsInMatch() then
        -- 1. القفز المستمر (بدون توقف)
        -- سيحاول القفز في كل إطار (Frame) متاح
        if hum:GetState() ~= Enum.HumanoidStateType.Jumping and hum:GetState() ~= Enum.HumanoidStateType.Freefall then
            hum.Jump = true
        elseif hum:GetState() == Enum.HumanoidStateType.Freefall then
            -- القفزة الثانية (Double Jump) أثناء السقوط
            hum.Jump = true
        end

        -- 2. المشي العشوائي المستمر
        if tick() - lastWalk > 0.4 then
            lastWalk = tick()
            hum:MoveTo(hrp.Position + Dirs[math.random(1, #Dirs)] * 15)
        end
    else
        -- التوقف تماماً في اللوبي (عندما لا توجد كرة متحركة)
        hum:Move(Vector3.new(0,0,0), false)
    end
end)

-- واجهة المستخدم (Neon Green)
local SG = Instance.new("ScreenGui", LP.PlayerGui)
SG.Name = "AL_AMIR_V12"

local Btn = Instance.new("TextButton", SG)
Btn.Size = UDim2.new(0, 110, 0, 50)
Btn.Position = UDim2.new(0, 15, 0.5, 0)
Btn.Text = "START V12"
Btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Btn.TextColor3 = Color3.fromRGB(0, 255, 100)
Btn.Font = Enum.Font.GothamBold
Instance.new("UICorner", Btn)
local Str = Instance.new("UIStroke", Btn)
Str.Color = Color3.fromRGB(0, 255, 100)
Str.Thickness = 2

Btn.MouseButton1Click:Connect(function()
    CFG.Active = not CFG.Active
    Btn.Text = CFG.Active and "ACTIVE ✅" or "START V12"
    Btn.BackgroundColor3 = CFG.Active and Color3.fromRGB(0, 100, 50) or Color3.fromRGB(20, 20, 20)
end)
