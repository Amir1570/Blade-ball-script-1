-- يقلل اللاج + يرفع FPS + ينضف الماب من الـ Effects

print("✅ Super Anti Lag Blade Ball Activated!")  -- هيظهر في console

local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

-- 1. إعدادات الـ Lighting (أقوى boost)
Lighting.GlobalShadows = false
Lighting.FogEnd = 100000
Lighting.Brightness = 1
Lighting.ClockTime = 14
Lighting.EnvironmentDiffuseScale = 0.2
Lighting.EnvironmentSpecularScale = 0.2
Lighting.Ambient = Color3.fromRGB(100, 100, 100)

-- 2. إزالة كل الـ Particles والـ Effects اللي بتسبب لاج في Blade Ball
local function CleanMap()
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or 
           obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then
            obj.Enabled = false
        end
        if obj:IsA("MeshPart") or obj:IsA("Part") then
            if obj:FindFirstChild("Trail") then obj.Trail.Enabled = false end
            if obj:FindFirstChild("ParticleEmitter") then obj.ParticleEmitter.Enabled = false end
        end
    end
end

CleanMap()

-- 3. تنظيف مستمر (كل 3 ثواني)
RunService.Heartbeat:Connect(function()
    if tick() % 3 < 0.1 then
        CleanMap()
    end
end)

-- 4. Extra FPS Boost (خاصة Blade Ball)
pcall(function()
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    game:GetService("Players").LocalPlayer.DevEnableMouseLock = false
end)

-- رسالة نهائية واضحة
game:GetService("StarterGui"):SetCore("SendNotification", {
    Title = "✅ Super Anti Lag",
