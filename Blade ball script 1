-- [4] محرك الحركة (المشي فقط في المباراة)
task.spawn(function()
    while task.wait() do
        if CFG.Walk and IsInMatch() then
            local char = LP.Character
            local hum = char and char:FindFirstChild("Humanoid")
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            if hum and hrp then
                hum:Move(Vector3.new(math.random(-1, 1), 0, math.random(-1, 1)), true)
                task.wait(0.5)
            end
        end
    end
end)

-- [5] محرك القفز المزدوج (قوة دفع خام)
UserInputService.JumpRequest:Connect(function()
    if CFG.Jump then
        local char = LP.Character
        local hum = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        
        if hum and hrp then
            if hum:GetState() == Enum.HumanoidStateType.Jumping or hum:GetState() == Enum.HumanoidStateType.Freefall then
                if JumpCount < 1 then
                    JumpCount = 1
                    hrp.Velocity = Vector3.new(hrp.Velocity.X, 65, hrp.Velocity.Z)
                end
            end
        end
    end
end)

RunService.Heartbeat:Connect(function()
    local char = LP.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum and hum.FloorMaterial ~= Enum.Material.Air then
        JumpCount = 0
    end
end)
