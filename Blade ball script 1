        ColorCorrection.Saturation = -1
        ColorCorrection.Parent = Lighting
        
        -- إعدادات الإضاءة
        Lighting.GlobalShadows = false
        Lighting.FogEnd = 9e9
        Lighting.FogStart = 9e9
        
        -- حلقة مستمرة لحذف المؤثرات
        antiLagConnection = RunService.Heartbeat:Connect(function()
            if not CFG.AntiLag then return end
            pcall(function()
                for _, v in ipairs(workspace:GetDescendants()) do
                    if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire") then
                        v:Destroy()
                    end
                    if v:IsA("BasePart") then
                        v.CastShadow = false
                    end
                end
                Lighting.GlobalShadows = false
            end)
        end)
        
        SetStatus("Anti-Lag ⚡", C.Yellow)
        
    else
        -- إيقاف Anti-Lag
        if antiLagConnection then antiLagConnection:Disconnect() end
        antiLagConnection = nil
        
        if ColorCorrection then ColorCorrection:Destroy() end
        ColorCorrection = nil
        
        Lighting.GlobalShadows = true
        Lighting.FogEnd = 100000
        Lighting.FogStart = 0
        Lighting.Brightness = 1
        
        SetStatus("خامل", C.Muted)
    end
end)

