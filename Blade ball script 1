Toggle(P3, "⚡  Super Anti-Lag", "رمادي + حذف مؤثرات = أداء أعلى", 3, function(on)
    CFG.AntiLag = on
    task.spawn(function()
        pcall(function()
            if on then
                -- 1. تحويل الشاشة للرمادي
                if ColorCorrection then pcall(function() ColorCorrection:Destroy() end) end
                ColorCorrection = Instance.new("ColorCorrectionEffect")
                ColorCorrection.Name = "BB_CC"
                ColorCorrection.Saturation = -1
                ColorCorrection.Brightness = 0.05
                ColorCorrection.Parent = game:GetService("Lighting")

                -- 2. إعدادات الإضاءة
                Lighting.GlobalShadows = false
                Lighting.FogEnd        = 9e8
                Lighting.FogStart      = 9e8
                Lighting.Brightness    = 2
                Lighting.ClockTime     = 14
                Lighting.Ambient       = Color3.fromRGB(178, 178, 178)
                Lighting.OutdoorAmbient = Color3.fromRGB(178, 178, 178)

                -- 3. حذف تأثيرات Lighting
                for _, v in ipairs(Lighting:GetChildren()) do
                    pcall(function()
                        if v:IsA("BloomEffect") or v:IsA("BlurEffect")
                        or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect")
                        or v:IsA("Sky") or v:IsA("Atmosphere") then
                            v:Destroy()
                        end
                    end)
                end

                -- 4. حذف تأثيرات workspace بالكامل
                for _, v in ipairs(workspace:GetDescendants()) do
                    pcall(function()
                        if v:IsA("ParticleEmitter") or v:IsA("Trail")
                        or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
                            v:Destroy()
                        end
                        if v:IsA("BloomEffect") or v:IsA("BlurEffect")
                        or v:IsA("SunRaysEffect") or v:IsA("ColorCorrectionEffect")
                        or v:IsA("DepthOfFieldEffect") then
                            v:Destroy()
                        end
                        if v:IsA("BasePart") then
                            v.CastShadow = false
                            v.Reflectance = 0
                            v.Material = Enum.Material.SmoothPlastic
                        end
                        if v:IsA("Decal") or v:IsA("Texture") then
                            v.Transparency = 1
                        end
                    end)
                end

                -- 5. تحديث مستمر لحذف أي تأثيرات جديدة
                RunService.Heartbeat:Connect(function()
                    if not CFG.AntiLag then return end
                    pcall(function()
                        for _, v in ipairs(workspace:GetDescendants()) do
                            if v:IsA("ParticleEmitter") or v:IsA("Trail")
                            or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then
                                pcall(function() v.Enabled = false end)
                            end
                        end
                    end)
                end)

            else
                -- إعادة الإعدادات
                if ColorCorrection then
                    pcall(function() ColorCorrection:Destroy() end)
                    ColorCorrection = nil
                end
                -- حذف أي ColorCorrection بقي
                pcall(function()
                    local cc = Lighting:FindFirstChild("BB_CC")
                    if cc then cc:Destroy() end
                end)

                Lighting.GlobalShadows  = true
                Lighting.FogEnd         = 100000
                Lighting.FogStart       = 0
                Lighting.Brightness     = 1
                Lighting.Ambient        = Color3.fromRGB(70, 70, 70)
                Lighting.OutdoorAmbient = Color3.fromRGB(100, 100, 100)
            end
        end)
    end)
    SetStatus(on and "Anti-Lag ⚡ (رمادي)" or "خامل", on and C.Yellow or nil)
end)

