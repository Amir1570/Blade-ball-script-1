-- AUTO PARRY LOOP
-- ══════════════════════════════════════════════
local lastParry = 0
local function TryParry()
    if tick() - lastParry < 0.2 then return end
    local char = LP.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local n = obj.Name:lower()
            if (n:find("ball") or n:find("blade") or n:find("orb") or n:find("proj")) then
                if (obj.Position - hrp.Position).Magnitude < 28 then
                    lastParry = tick()
                    task.delay(CFG.ParryDelay, function()
                        local names = {
                            "Parry","ParryEvent","parry","ParryBall",
                            "RE","Remote","Block","BlockEvent",
                            "Deflect","DeflectEvent","parryEvent"
                        }
                        for _, rn in ipairs(names) do
                            local r = RS:FindFirstChild(rn, true)
                            if r and r:IsA("RemoteEvent") then
                                pcall(function() r:FireServer() end)
                                SetStatus("تم الصد! 🛡", COL.Green)
                                Log("صد ناجح 🛡 dist=" ..
                                    math.floor((obj.Position - hrp.Position).Magnitude), COL.Green)
                                return
                            end
                        end
                    end)
                    break
                end
            end
        end
    end
end

-- ══════════════════════════════════════════════
-- MOVEMENT LOOPS
-- ══════════════════════════════════════════════
local lastJump   = 0
local lastWalk   = 0
local lastRandom = 0

local Dirs = {
    Vector3.new(1,0,0),  Vector3.new(-1,0,0),
    Vector3.new(0,0,1),  Vector3.new(0,0,-1),
    Vector3.new(1,0,1).Unit, Vector3.new(-1,0,-1).Unit,
    Vector3.new(1,0,-1).Unit, Vector3.new(-1,0,1).Unit,
}

RunService.Heartbeat:Connect(function()
    pcall(function()
        local char = LP.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not hrp or not hum then return end
        local now = tick()

        -- Auto Parry
        if CFG.AutoParry then TryParry() end

        -- Auto Jump
        if CFG.AutoJump and now - lastJump >= CFG.JumpInterval then
            lastJump = now
            hum.Jump = true
        end

        -- Auto Walk (random direction)
        if CFG.AutoWalk and now - lastWalk >= CFG.WalkInterval then
            lastWalk = now
            local dir = Dirs[math.random(1, #Dirs)]
            hum:MoveTo(hrp.Position + dir * 20)
        end

        -- Random Movement
        if CFG.RandomMove and now - lastRandom >= CFG.MoveInterval then
            lastRandom = now
            local dir = Dirs[math.random(1, #Dirs)]
            hum:MoveTo(hrp.Position + dir * 16)
        end
    end)
end)

